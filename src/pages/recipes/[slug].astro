---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const recipes = await getCollection('recipes');
  return recipes.map(recipe => ({
    params: { slug: recipe.id.split('/').pop() },
    props:  { recipe },
  }));
}

const { recipe } = Astro.props;
const { Content } = await render(recipe);
const { title, category, prepTime, cookTime, yield: yieldText, intro, tags, dietary, panVariants, directions, hasNotes } = recipe.data;
---

<Layout title={title}>
  <main class="recipe-page">

    <!-- ── HERO ── -->
    <section class="recipe-hero">
      <div class="container">
        <div class="recipe-hero__meta">
          <span class="recipe-hero__category">{category}</span>
        </div>
        <h1 class="recipe-hero__title">{title}</h1>
        {intro && (
          <p class="recipe-hero__intro" set:html={intro} />
        )}
        <div class="recipe-hero__stats">
          {prepTime && (
            <div class="stat">
              <span class="stat__label">Prep</span>
              <span class="stat__value">{prepTime}</span>
            </div>
          )}
          {cookTime && (
            <div class="stat">
              <span class="stat__label">Cook</span>
              <span class="stat__value">{cookTime}</span>
            </div>
          )}
          {yieldText && (
            <div class="stat">
              <span class="stat__label">Yield</span>
              <span class="stat__value" id="servings-display">{yieldText}</span>
            </div>
          )}
        </div>
        {((tags && tags.length > 0) || (dietary && dietary.length > 0)) && (
          <div class="recipe-hero__tags">
            {tags && tags.map(tag => (
              <span class="tag tag--personal">{tag}</span>
            ))}
            {dietary && dietary.map(flag => (
              <span class="tag tag--dietary">{flag}</span>
            ))}
          </div>
        )}
      </div>
    </section>

    <!-- ── INGREDIENTS ── -->
    <section class="recipe-section recipe-section--ingredients">
        <div class="container">
          <h2>Ingredients</h2>

          {panVariants && panVariants.length > 1 && (
            <div class="pan-tabs" role="tablist" aria-label="Pan size">
              {panVariants.map((variant, i) => (
                <button
                  class={`pan-tab${i === 0 ? ' pan-tab--active' : ''}`}
                  role="tab"
                  aria-selected={i === 0 ? 'true' : 'false'}
                  data-tab={variant.id}
                  data-yield={variant.yield}
                >
                  {variant.label}
                </button>
              ))}
            </div>
          )}

          {panVariants && panVariants.map((variant, i) => (
            <ul
              class={`ingredient-list${i !== 0 ? ' ingredient-list--hidden' : ''}`}
              data-panel={variant.id}
            >
              {variant.ingredients.map(item => (
                <li>{item}</li>
              ))}
            </ul>
          ))}
        </div>
      </section>

    <!-- ── DIRECTIONS ── -->
    <section class="recipe-section recipe-section--directions">
      <div class="container">
        <h2>Directions</h2>
        <ol class="step-list">
          {directions && directions.map((step, i) => (
            <li class="step">
              <span class="step__number">{i + 1}</span>
              <div class="step__content">
                <h3 class="step__title">{step.title}</h3>
                <p set:html={step.body} />
              </div>
            </li>
          ))}
        </ol>
      </div>
    </section>

    {hasNotes && (
      <section class="recipe-section recipe-section--notes">
        <div class="container">
          <h2>Notes</h2>
          <div class="recipe-notes">
            <Content />
          </div>
        </div>
      </section>
    )}  

  </main>
</Layout>

<style>

  /* ── PAGE WRAPPER ── */
  .recipe-page {
    padding-bottom: var(--space-20);
  }

  .recipe-page .container {
    max-width: 860px;
  }

  /* ── HERO ── */
  .recipe-hero {
    padding: var(--space-12) 0 var(--space-10);
  }

  .recipe-hero__meta {
    margin-bottom: var(--space-3);
  }

  .recipe-hero__category {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    font-weight: 200;
    font-style: italic;
    color: var(--color-accent-2);
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .recipe-hero__title {
    font-size: clamp(var(--text-3xl), 5vw, var(--text-4xl));
    color: var(--color-text);
    margin-bottom: var(--space-5);
  }

  .recipe-hero__intro {
    font-size: var(--text-lg);
    color: var(--color-text-muted);
    max-width: var(--max-width-prose);
    margin-bottom: var(--space-8);
    line-height: 1.7;
  }

  .recipe-hero__stats {
    display: flex;
    gap: var(--space-8);
  }

  .recipe-notes {
    font-size: var(--text-base);
    color: var(--color-text-muted);
    line-height: 1.75;
    max-width: var(--max-width-prose);
  }

  .recipe-notes p {
    max-width: var(--max-width-prose);
    margin-bottom: var(--space-4);
  }

  .stat {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .stat__label {
    font-size: var(--text-xs);
    font-weight: 200;
    font-style: italic;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .stat__value {
    font-family: var(--font-serif);
    font-size: var(--text-lg);
    color: var(--color-text);
  }

  /* ── TAGS ── */
  .recipe-hero__tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin-top: var(--space-6);
  }

  .tag {
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    font-weight: 400;
    letter-spacing: 0.04em;
    padding: var(--space-1) var(--space-3);
    border-radius: var(--radius-sm);
    white-space: nowrap;
  }

  .tag--personal {
    background: rgba(222, 124, 90, 0.12);
    color: var(--color-accent-2);
    border: 1px solid rgba(222, 124, 90, 0.3);
  }

  .tag--dietary {
    background: rgba(118, 130, 95, 0.12);
    color: var(--color-accent-1);
    border: 1px solid rgba(118, 130, 95, 0.3);
  }

  /* ── SECTIONS ── */
  .recipe-section {
    padding: var(--space-12) 0;
  }

  .recipe-section h2 {
    margin-bottom: var(--space-6);
  }

  .recipe-hero .container,
  .recipe-section .container {
    border-bottom: 3px solid rgba(121, 59, 2, 0.15);
    padding-bottom: var(--space-10);
  }

  /* ── PAN TABS ── */
  .pan-tabs {
    display: flex;
    gap: var(--space-2);
    margin-bottom: var(--space-6);
  }

  .pan-tab {
    background: none;
    border: 1px solid var(--color-accent-1);
    border-radius: var(--radius-sm);
    color: var(--color-accent-1);
    cursor: pointer;
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    padding: var(--space-2) var(--space-4);
    transition: background var(--transition-fast), color var(--transition-fast);
  }

  .pan-tab--active {
    background: var(--color-accent-1);
    color: var(--cream);
  }

  .pan-tab:hover:not(.pan-tab--active) {
    background: rgba(118, 130, 95, 0.1);
  }

  /* ── INGREDIENTS ── */

  .ingredient-list {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .ingredient-list--hidden {
    display: none;
  }

  .ingredient-list li {
    font-size: var(--text-base);
    padding: var(--space-3) 0;
    border-bottom: 1px solid rgba(118, 130, 95, 0.15);
    display: flex;
    align-items: baseline;
    gap: var(--space-3);
  }

  .ingredient-list li::before {
    content: '';
    display: inline-block;
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--color-accent-2);
    flex-shrink: 0;
    position: relative;
    top: -2px;
  }

  /* ── STEPS ── */
  .step-list {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-10);
  }

  .step {
    display: flex;
    flex-direction: row;
    gap: var(--space-4);
    align-items: flex-start;
  }

  .step__number {
    font-family: var(--font-serif);
    font-size: var(--text-xl);
    font-weight: 700;
    color: var(--color-accent-2);
    line-height: 1.3;
    padding-top: 0;
    min-width: 1.75rem;
    flex-shrink: 0;
  }

  .step__title {
    font-family: var(--font-serif);
    font-size: var(--text-xl);
    font-weight: 700;
    margin-bottom: var(--space-3);
    color: var(--color-text);
    line-height: 1.3;
  }

  .step__content p {
    color: var(--color-text-muted);
    line-height: 1.75;
    max-width: var(--max-width-prose);
  }
</style>

<script>
  const tabs = document.querySelectorAll('.pan-tab');
  const panels = document.querySelectorAll('.ingredient-list');
  const servingsDisplay = document.getElementById('servings-display');

  tabs.forEach(tab => {
    tab.addEventListener('click', () => {
      const target = tab.dataset.tab;
      const servings = tab.dataset.servings;

      tabs.forEach(t => {
        t.classList.remove('pan-tab--active');
        t.setAttribute('aria-selected', 'false');
      });

      tab.classList.add('pan-tab--active');
      tab.setAttribute('aria-selected', 'true');

      panels.forEach(panel => {
        panel.classList.toggle('ingredient-list--hidden', panel.dataset.panel !== target);
      });

      if (servingsDisplay) {
        servingsDisplay.textContent = tab.dataset.yield;
      }
    });
  });
</script>