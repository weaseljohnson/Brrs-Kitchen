---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';
import { buildRecipeSchema } from '../../utils/seo';

export async function getStaticPaths() {
  const recipes = await getCollection('recipes');
  return recipes.map(recipe => ({
    params: { slug: recipe.id.split('/').pop() },
    props:  { recipe },
  }));
}

const { recipe } = Astro.props;
const { Content } = await render(recipe);
const { title, category, prepTime, cookTime, yield: yieldText, intro, tags, dietary, panVariants, directions, hasNotes, image, credit } = recipe.data;

const recipeSchema = buildRecipeSchema(recipe.data, Astro.url.href, Astro.url.origin);
const ogImage      = image ?? '/images/og/og-default.jpg';
---

<Layout
  title={title}
  description={intro ?? ''}
  ogImage={ogImage}
  ogType="article"
  schema={[recipeSchema]}
>
  <main class="recipe-page">

    <!-- ── RECIPE HEADER ── -->
    <section class="recipe-hero">
      <div class="container">
        <div class="recipe-header-box">

          <!-- Image wrapper — straddles the top border of the box -->
          <div class="recipe-header__img-wrap">
            {image
              ? <img src={image} alt={title} class="recipe-header__img" />
              : <div class="recipe-header__img-placeholder" aria-hidden="true"></div>
            }
          </div>

          <!-- Centered content block -->
          <div class="recipe-header__content">
            <span class="recipe-hero__category">{category}</span>
            <h1 class="recipe-hero__title">{title}</h1>
            {intro && (
              <p class="recipe-hero__intro" set:html={intro} />
            )}

            {credit && (
              <p class="recipe-credit">
                Credit: <a href={credit.url} target="_blank" rel="noopener noreferrer">{credit.name}</a>
              </p>
            )}

            <div class="recipe-hero__actions">
              <a
                href={`/recipes/print/${Astro.params.slug}?pan=${panVariants?.[0]?.id ?? ''}`}
                target="_blank"
                rel="noopener noreferrer"
                class="recipe-btn recipe-btn--print"
                id="print-btn"
                data-base-href={`/recipes/print/${Astro.params.slug}`}
              >
                Print Recipe
              </a>
              <a
                href={`https://pinterest.com/pin/create/button/?url=${encodeURIComponent(Astro.url.href)}&description=${encodeURIComponent(title)}`}
                target="_blank"
                rel="noopener noreferrer"
                class="recipe-btn recipe-btn--pin"
              >
                Pin Recipe
              </a>
            </div>

            <div class="recipe-hero__stats">
              {prepTime && (
                <div class="stat">
                  <span class="stat__label">Prep</span>
                  <span class="stat__value">{prepTime}</span>
                </div>
              )}
              {cookTime && (
                <div class="stat">
                  <span class="stat__label">Cook</span>
                  <span class="stat__value">{cookTime}</span>
                </div>
              )}
              {yieldText && (
                <div class="stat">
                  <span class="stat__label">Yield</span>
                  <span class="stat__value" id="servings-display" data-original={yieldText}>{yieldText}</span>
                </div>
              )}
            </div>

            {((tags && tags.length > 0) || (dietary && dietary.length > 0)) && (
              <div class="recipe-hero__tags">
                {tags && tags.map(tag => (
                  <span class="tag tag--personal">{tag}</span>
                ))}
                {dietary && dietary.map(flag => (
                  <span class="tag tag--dietary">{flag}</span>
                ))}
              </div>
            )}
          </div>

        </div>
      </div>
    </section>

    <!-- ── INGREDIENTS ── -->
    <section class="recipe-section recipe-section--ingredients">
        <div class="container">
          <h2>Ingredients</h2>

          {panVariants && panVariants.length > 1 && (
            <div class="pan-tabs" role="tablist" aria-label="Pan size">
              {panVariants.map((variant, i) => (
                <button
                  class={`pan-tab${i === 0 ? ' pan-tab--active' : ''}`}
                  role="tab"
                  aria-selected={i === 0 ? 'true' : 'false'}
                  data-tab={variant.id}
                  data-yield={variant.yield}
                >
                  {variant.label}
                </button>
              ))}
            </div>
          )}

          <div class="scale-control" role="group" aria-label="Recipe scale">
            <span class="scale-control__label">Scale</span>
            <div class="scale-options">
              {[
                { value: '0.5', label: '½×' },
                { value: '1',   label: '1×' },
                { value: '2',   label: '2×' },
              ].map(opt => (
                <label class="scale-option">
                  <input
                    type="radio"
                    name="recipe-scale"
                    value={opt.value}
                    checked={opt.value === '1'}
                    class="scale-option__input"
                  />
                  <span class="scale-option__label">{opt.label}</span>
                </label>
              ))}
            </div>
          </div>

          {panVariants && panVariants.map((variant, i) => (
            <ul
              class={`ingredient-list${i !== 0 ? ' ingredient-list--hidden' : ''}`}
              data-panel={variant.id}
            >
              {variant.ingredients.map(ingredient => (
                <li data-original={ingredient.count ?? ''}>
                  <span class="ingredient-text">
                    {ingredient.count && (
                      <span class="ingredient-count">{ingredient.count}</span>
                    )}<span class="ingredient-item">{ingredient.count ? ' ' : ''}{ingredient.item}</span>
                  </span>
                </li>
              ))}
            </ul>
          ))}
        </div>
      </section>

    <!-- ── DIRECTIONS ── -->
    <section class="recipe-section recipe-section--directions">
      <div class="container">
        <h2>Directions</h2>
        <ol class="step-list">
          {directions && directions.map((step, i) => (
            <li class="step">
              <span class="step__number">{i + 1}</span>
              <div class="step__content">
                <h3 class="step__title">{step.title}</h3>
                <p set:html={step.body} />
              </div>
            </li>
          ))}
        </ol>
      </div>
    </section>

    {hasNotes && (
      <section class="recipe-section recipe-section--notes">
        <div class="container">
          <h2>Notes</h2>
          <div class="recipe-notes">
            <Content />
          </div>
        </div>
      </section>
    )}  

  </main>
</Layout>

<style>

  /* ── PAGE WRAPPER ── */
  .recipe-page {
    padding-bottom: var(--space-20);
  }

  .recipe-page .container {
    max-width: 860px;
  }

  /* ── HERO ── */
  .recipe-hero {
    padding: var(--space-6) 0 var(--space-10);
  }

  .recipe-header-box {
    position: relative;
    margin-top: 192px;
    border: 1px solid var(--color-accent-2);
    border-radius: var(--radius-lg);
    padding: 208px var(--space-8) var(--space-10);
    text-align: center;
  }

  .recipe-header__img-wrap {
    position: absolute;
    top: 0;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 540px;
    background: var(--color-bg);
    padding: var(--space-3);
    border-radius: calc(var(--radius-md) + var(--space-3));
  }

  .recipe-header__img-placeholder {
    width: 100%;
    aspect-ratio: 3 / 2;
    background: rgba(118, 130, 95, 0.08);
    border-radius: var(--radius-md);
  }

  .recipe-header__img {
    width: 100%;
    aspect-ratio: 3 / 2;
    object-fit: cover;
    border-radius: var(--radius-md);
    display: block;
  }

  @media (max-width: 768px) {
    .recipe-header__img-wrap {
      width: 75%;
    }

    .recipe-header-box {
      margin-top: 100px;
      padding-top: 116px;
    }
  }

  .recipe-header__content {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .recipe-hero__category {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    font-weight: 200;
    font-style: italic;
    color: var(--color-accent-2);
    letter-spacing: 0.05em;
    text-transform: uppercase;
    margin-bottom: var(--space-2);
  }

  .recipe-hero__title {
    font-size: clamp(var(--text-3xl), 5vw, var(--text-4xl));
    color: var(--color-text);
    margin-bottom: var(--space-4);
  }

  .recipe-hero__intro {
    font-size: var(--text-lg);
    color: var(--color-text-muted);
    max-width: var(--max-width-prose);
    margin-bottom: var(--space-8);
    line-height: 1.7;
    text-align: center;
  }

  /* ── ACTION BUTTONS ── */
  .recipe-hero__actions {
    display: flex;
    justify-content: center;
    gap: var(--space-3);
    margin-bottom: var(--space-8);
  }

  .recipe-btn {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    font-weight: 400;
    padding: var(--space-2) var(--space-6);
    border-radius: var(--radius-sm);
    cursor: pointer;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    transition:
      background var(--transition-fast),
      color var(--transition-fast),
      border-color var(--transition-fast);
  }

  .recipe-btn--print {
    background: rgba(206, 212, 196, 0.35);
    border: 1px solid var(--color-accent-1);
    color: var(--color-text);
  }

  .recipe-btn--print:hover {
    background: rgba(118, 130, 95, 0.25);
    border-color: var(--color-accent-1);
    color: var(--color-text);
  }

  .recipe-btn--pin {
    background: rgba(189, 8, 28, 0.08);
    border: 1px solid rgba(189, 8, 28, 0.4);
    color: #bd081c;
  }

  .recipe-btn--pin:hover {
    background: rgba(189, 8, 28, 0.18);
    border-color: rgba(189, 8, 28, 0.7);
    color: #9a0616;
  } 

  .recipe-hero__stats {
    display: flex;
    justify-content: center;
    gap: var(--space-8);
    margin-bottom: var(--space-6);
  }

  .recipe-notes {
    font-size: var(--text-base);
    color: var(--color-text-muted);
    line-height: 1.75;
    max-width: var(--max-width-prose);
  }

  .recipe-notes p {
    max-width: var(--max-width-prose);
    margin-bottom: var(--space-4);
  }

  .stat {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .stat__label {
    font-size: var(--text-xs);
    font-weight: 200;
    font-style: italic;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .stat__value {
    font-family: var(--font-serif);
    font-size: var(--text-lg);
    color: var(--color-text);
  }

  /* ── TAGS ── */
  .recipe-hero__tags {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--space-2);
  }

  .tag {
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    font-weight: 400;
    letter-spacing: 0.04em;
    padding: var(--space-1) var(--space-3);
    border-radius: var(--radius-sm);
    white-space: nowrap;
  }

  .tag--personal {
    background: rgba(222, 124, 90, 0.12);
    color: var(--color-accent-2);
    border: 1px solid rgba(222, 124, 90, 0.3);
  }

  .tag--dietary {
    background: rgba(118, 130, 95, 0.12);
    color: var(--color-accent-1);
    border: 1px solid rgba(118, 130, 95, 0.3);
  }

  /* ── CREDIT ── */
  .recipe-credit {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    font-weight: 200;
    font-style: italic;
    color: var(--color-text-muted);
    margin-bottom: var(--space-6);
    max-width: none;
    text-align: center;
  }

  .recipe-credit a {
    color: var(--color-accent-2);
    text-decoration: underline;
    text-underline-offset: 3px;
    font-style: italic;
  }

  /* ── SCALE CONTROL ── */
  .scale-control {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    margin-bottom: var(--space-6);
  }

  .scale-control__label {
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    font-weight: 200;
    font-style: italic;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    white-space: nowrap;
  }

  .scale-options {
    display: flex;
    gap: 0;
    border: 1px solid var(--color-accent-1);
    border-radius: var(--radius-sm);
    overflow: hidden;
  }

  .scale-option {
    cursor: pointer;
  }

  .scale-option__input {
    display: none;
  }

  .scale-option__label {
    display: block;
    padding: var(--space-2) var(--space-4);
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    color: var(--color-accent-1);
    border-right: 1px solid var(--color-accent-1);
    transition: background var(--transition-fast), color var(--transition-fast);
    user-select: none;
  }

  .scale-option:last-child .scale-option__label {
    border-right: none;
  }

  .scale-option__input:checked + .scale-option__label {
    background: var(--color-accent-1);
    color: var(--cream);
  }

  .scale-option:hover .scale-option__input:not(:checked) + .scale-option__label {
    background: rgba(118, 130, 95, 0.1);
  }

  /* ── SECTIONS ── */
  .recipe-section {
    padding: var(--space-12) 0;
  }

  .recipe-section h2 {
    margin-bottom: var(--space-6);
  }

  .recipe-hero .container,
  .recipe-section .container {
    border-bottom: 3px solid rgba(121, 59, 2, 0.15);
    padding-bottom: var(--space-10);
  }

  /* ── PAN TABS ── */
  .pan-tabs {
    display: flex;
    gap: var(--space-2);
    margin-bottom: var(--space-6);
  }

  .pan-tab {
    background: none;
    border: 1px solid var(--color-accent-1);
    border-radius: var(--radius-sm);
    color: var(--color-accent-1);
    cursor: pointer;
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    padding: var(--space-2) var(--space-4);
    transition: background var(--transition-fast), color var(--transition-fast);
  }

  .pan-tab--active {
    background: var(--color-accent-1);
    color: var(--cream);
  }

  .pan-tab:hover:not(.pan-tab--active) {
    background: rgba(118, 130, 95, 0.1);
  }

  /* ── INGREDIENTS ── */

  .ingredient-list {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .ingredient-list--hidden {
    display: none;
  }

  .ingredient-list li {
    font-size: var(--text-base);
    padding: var(--space-3) 0;
    border-bottom: 1px solid rgba(118, 130, 95, 0.15);
    display: flex;
    align-items: baseline;
    gap: var(--space-3);
  }

  .ingredient-list li::before {
    content: '';
    display: inline-block;
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--color-accent-2);
    flex-shrink: 0;
    position: relative;
    top: -2px;
  }

  .ingredient-text {
    flex: 1;
  }

  .ingredient-count {
    color: var(--color-text);
  }

  .ingredient-item {
    color: var(--color-text-muted);
  }

  /* ── STEPS ── */
  .step-list {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-10);
  }

  .step {
    display: flex;
    flex-direction: row;
    gap: var(--space-4);
    align-items: flex-start;
  }

  .step__number {
    font-family: var(--font-serif);
    font-size: var(--text-xl);
    font-weight: 700;
    color: var(--color-accent-2);
    line-height: 1.3;
    padding-top: 0;
    min-width: 1.75rem;
    flex-shrink: 0;
  }

  .step__title {
    font-family: var(--font-serif);
    font-size: var(--text-xl);
    font-weight: 700;
    margin-bottom: var(--space-3);
    color: var(--color-text);
    line-height: 1.3;
  }

  .step__content p {
    color: var(--color-text-muted);
    line-height: 1.75;
    max-width: var(--max-width-prose);
  }
</style>

<script>
  import { scaleCount, scaleYield } from '../../scripts/scaleIngredients';

  // ── STATE ──
  let currentScale = 1;

  // ── REFS ──
  const tabs           = document.querySelectorAll<HTMLButtonElement>('.pan-tab');
  const panels         = document.querySelectorAll<HTMLElement>('.ingredient-list');
  const servingsDisplay = document.getElementById('servings-display') as HTMLElement | null;
  const printBtn       = document.getElementById('print-btn') as HTMLAnchorElement | null;
  const scaleInputs    = document.querySelectorAll<HTMLInputElement>('input[name="recipe-scale"]');

  // ── HELPERS ──
  function getActivePanId(): string {
    return document.querySelector<HTMLButtonElement>('.pan-tab--active')?.dataset.tab ?? '';
  }

  function updatePrintUrl(): void {
    if (printBtn) {
      printBtn.href = `${printBtn.dataset.baseHref}?pan=${getActivePanId()}&scale=${currentScale}`;
    }
  }

  function applyScaleToVisible(): void {
    document
      .querySelectorAll<HTMLLIElement>('.ingredient-list:not(.ingredient-list--hidden) li')
      .forEach(li => {
        const countSpan = li.querySelector<HTMLSpanElement>('.ingredient-count');
        if (countSpan) {
          countSpan.textContent = scaleCount(li.dataset.original ?? '', currentScale);
        }
      });

    if (servingsDisplay?.dataset.original) {
      servingsDisplay.textContent = scaleYield(servingsDisplay.dataset.original, currentScale);
    }
  }

  // ── PAN TABS ──
  tabs.forEach(tab => {
    tab.addEventListener('click', () => {
      const target = tab.dataset.tab;

      tabs.forEach(t => {
        t.classList.remove('pan-tab--active');
        t.setAttribute('aria-selected', 'false');
      });
      tab.classList.add('pan-tab--active');
      tab.setAttribute('aria-selected', 'true');

      panels.forEach(panel => {
        panel.classList.toggle('ingredient-list--hidden', panel.dataset.panel !== target);
      });

      // Update yield baseline to this variant, then re-scale
      if (servingsDisplay && tab.dataset.yield) {
        servingsDisplay.dataset.original = tab.dataset.yield;
      }

      applyScaleToVisible();
      updatePrintUrl();
    });
  });

  // ── SCALE CONTROL ──
  scaleInputs.forEach(input => {
    input.addEventListener('change', () => {
      currentScale = parseFloat(input.value);
      applyScaleToVisible();
      updatePrintUrl();
    });
  });

  // ── INIT ──
  updatePrintUrl();
</script>