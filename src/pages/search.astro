---
export const prerender = true;
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Search Recipes"
  description="Search all recipes on Brr's Kitchen."
>
  <main class="search-page">
    <div class="container">

      <div class="search-header">
        <h1>Search Recipes</h1>
        <div class="search-bar-wrap">
          <svg class="search-bar-wrap__icon" width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <circle cx="6.5" cy="6.5" r="5" stroke="currentColor" stroke-width="1.5"/>
            <line x1="10.5" y1="10.5" x2="14.5" y2="14.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
          <label for="search-page-input" class="sr-only">Search recipes</label>
          <input
            type="search"
            id="search-page-input"
            class="search-page-input"
            placeholder="Search recipes…"
            aria-label="Search recipes"
            autocomplete="off"
          />
        </div>
      </div>

      <p class="search-status" id="search-status" aria-live="polite"></p>

      <ul class="search-results" id="search-results" role="list"></ul>

    </div>
  </main>
</Layout>

<style>
  .search-page {
    padding: var(--space-12) 0 var(--space-20);
  }

  .search-header {
    margin-bottom: var(--space-8);
  }

  .search-header h1 {
    margin-bottom: var(--space-5);
  }

  /* ── SEARCH BAR ── */
  .search-bar-wrap {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    background: rgba(118, 130, 95, 0.07);
    border: 1px solid rgba(118, 130, 95, 0.28);
    border-radius: 999px;
    padding: var(--space-3) var(--space-5);
    max-width: 480px;
    transition: border-color var(--transition-fast), background var(--transition-fast);
  }

  .search-bar-wrap:focus-within {
    border-color: var(--color-accent-1);
    background: rgba(118, 130, 95, 0.12);
  }

  .search-bar-wrap__icon {
    color: var(--color-text-muted);
    flex-shrink: 0;
  }

  .search-page-input {
    flex: 1;
    border: none;
    background: none;
    outline: none;
    font-family: var(--font-sans);
    font-size: var(--text-base);
    color: var(--color-text);
  }

  .search-page-input::placeholder {
    color: var(--color-text-muted);
  }

  .search-page-input::-webkit-search-cancel-button {
    display: none;
  }

  /* ── STATUS ── */
  .search-status {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    font-style: italic;
    color: var(--color-text-muted);
    margin-bottom: var(--space-6);
    min-height: 1.4em;
    max-width: none;
  }

  /* ── RESULTS ── */
  .search-results {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .result-card {
    display: flex;
    align-items: center;
    gap: var(--space-5);
    padding: var(--space-4);
    border: 1px solid rgba(118, 130, 95, 0.15);
    border-radius: var(--radius-md);
    text-decoration: none;
    color: inherit;
    transition: background var(--transition-fast), border-color var(--transition-fast);
  }

  .result-card:hover {
    background: rgba(118, 130, 95, 0.04);
    border-color: rgba(118, 130, 95, 0.3);
    color: inherit;
  }

  .result-card__img {
    width: 80px;
    height: 80px;
    object-fit: cover;
    border-radius: var(--radius-sm);
    flex-shrink: 0;
    background: rgba(118, 130, 95, 0.08);
  }

  .result-card__img-placeholder {
    width: 80px;
    height: 80px;
    border-radius: var(--radius-sm);
    flex-shrink: 0;
    background: rgba(118, 130, 95, 0.08);
  }

  .result-card__body {
    flex: 1;
    min-width: 0;
  }

  .result-card__category {
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    font-weight: 200;
    font-style: italic;
    color: var(--color-accent-2);
    letter-spacing: 0.05em;
    text-transform: uppercase;
    margin-bottom: var(--space-1);
  }

  .result-card__title {
    font-family: var(--font-serif);
    font-size: var(--text-lg);
    font-weight: 700;
    color: var(--color-text);
    margin-bottom: var(--space-2);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .result-card__excerpt {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    max-width: none;
  }

  /* Strip Pagefind's highlight marks from excerpts */
  .result-card__excerpt mark {
    background: none;
    color: var(--color-accent-3);
    font-weight: 500;
  }

  @media (max-width: 480px) {
    .result-card__img,
    .result-card__img-placeholder {
      width: 60px;
      height: 60px;
    }
  }
</style>

<script>
  const input      = document.getElementById('search-page-input') as HTMLInputElement;
  const statusEl   = document.getElementById('search-status')!;
  const resultsEl  = document.getElementById('search-results')!;

  let pagefind: any = null;

  async function loadPagefind() {
    if (pagefind) return;
    try {
      // @ts-ignore — pagefind index is generated at build time, not resolvable by Vite
      pagefind = await import('/pagefind/pagefind.js');
      await pagefind.init();
    } catch {
      pagefind = null;
    }
  }

  async function runSearch(query: string) {
    if (!query.trim()) {
      statusEl.textContent = '';
      resultsEl.innerHTML  = '';
      return;
    }

    await loadPagefind();
    if (!pagefind) {
      statusEl.textContent = 'Search unavailable — run a production build to enable it.';
      return;
    }

    statusEl.textContent = 'Searching…';

    const search = await pagefind.search(query);

    if (search.results.length === 0) {
      statusEl.textContent = `No results for "${query}"`;
      resultsEl.innerHTML  = '';
      return;
    }

    statusEl.textContent = `${search.results.length} result${search.results.length === 1 ? '' : 's'} for "${query}"`;

    const data = await Promise.all(search.results.map((r: any) => r.data()));

    resultsEl.innerHTML = data.map(result => {
      const image    = result.meta?.image ?? '';
      const category = result.meta?.category ?? '';
      const imgEl    = image
        ? `<img src="${image}" alt="" class="result-card__img" loading="lazy" />`
        : `<div class="result-card__img-placeholder" aria-hidden="true"></div>`;

      return `
        <li>
          <a href="${result.url}" class="result-card">
            ${imgEl}
            <div class="result-card__body">
              ${category ? `<p class="result-card__category">${category}</p>` : ''}
              <p class="result-card__title">${result.meta?.title ?? 'Untitled'}</p>
              <p class="result-card__excerpt">${result.excerpt}</p>
            </div>
          </a>
        </li>
      `;
    }).join('');
  }

  // ── READ ?q= FROM URL ON LOAD ──
  const params = new URLSearchParams(window.location.search);
  const initial = params.get('q') ?? '';
  if (initial) {
    input.value = initial;
    runSearch(initial);
  }

  // ── LIVE SEARCH AS USER TYPES ──
  let debounceTimer: ReturnType<typeof setTimeout>;
  input.addEventListener('input', () => {
    clearTimeout(debounceTimer);
    debounceTimer = setTimeout(() => runSearch(input.value), 250);
  });

  // ── UPDATE URL WITHOUT RELOADING (keeps shareable/back-button state) ──
  input.addEventListener('input', () => {
    const url = new URL(window.location.href);
    if (input.value.trim()) {
      url.searchParams.set('q', input.value.trim());
    } else {
      url.searchParams.delete('q');
    }
    history.replaceState(null, '', url.toString());
  });

  // ── AUTO-FOCUS ──
  input.focus();
</script>