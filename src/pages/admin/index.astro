---
export const prerender = false;
import AdminLayout from '../../layouts/AdminLayout.astro';
import yaml from 'js-yaml';
import AdminPageSwitcher from '../../components/AdminPageSwitcher.astro';

const GITHUB_TOKEN  = import.meta.env.GITHUB_TOKEN;
const GITHUB_OWNER  = import.meta.env.GITHUB_OWNER;
const GITHUB_REPO   = import.meta.env.GITHUB_REPO;
const GITHUB_BRANCH = import.meta.env.GITHUB_BRANCH;

const authHeader = {
  Authorization: `Bearer ${GITHUB_TOKEN}`,
  Accept: 'application/vnd.github+json',
};

let recipes = [];
let fetchError = null;

try {
  const treeRes = await fetch(
    `https://api.github.com/repos/${GITHUB_OWNER}/${GITHUB_REPO}/git/trees/${GITHUB_BRANCH}?recursive=1`,
    { headers: authHeader }
  );
  if (!treeRes.ok) throw new Error(`GitHub API error: ${treeRes.statusText}`);

  const treeData = await treeRes.json();

  const recipeFiles = (treeData.tree ?? []).filter(
    f => f.type === 'blob'
      && f.path.startsWith('content/recipes/')
      && f.path.endsWith('.md')
      && !f.path.includes('.gitkeep')
  );

  recipes = await Promise.all(
    recipeFiles.map(async (file) => {
      const res = await fetch(
        `https://api.github.com/repos/${GITHUB_OWNER}/${GITHUB_REPO}/contents/${file.path}`,
        { headers: authHeader }
      );
      if (!res.ok) return null;

      const fileData = await res.json();
      const content  = Buffer.from(fileData.content, 'base64').toString('utf8');
      const match    = content.match(/^---\r?\n([\s\S]*?)\r?\n---/);
      const fm: any  = match ? (yaml.load(match[1]) ?? {}) : {};

      const slug       = file.path.split('/').pop()!.replace('.md', '');
      const folderName = file.path.split('/').slice(-2, -1)[0];

      return {
        slug,
        filePath: file.path,
        folderName,
        title:    fm.title    ?? slug,
        category: fm.category ?? folderName,
        image:    fm.image    ?? null,
        draft:    fm.draft    === true,
        archived: fm.archived === true,
        pubDate:  fm.pubDate  ?? '',
      };
    })
  );

  recipes = recipes
    .filter(Boolean)
    .sort((a, b) => b.pubDate.localeCompare(a.pubDate));

} catch (err: any) {
  fetchError = err.message;
}

const published = recipes.filter(r => !r.draft && !r.archived);
const drafts    = recipes.filter(r =>  r.draft  && !r.archived);
const archived  = recipes.filter(r =>  r.archived);
---

<AdminLayout title="Dashboard">

  {fetchError && (
    <div class="dash-error">
      ⚠️ Could not load recipes: {fetchError}
    </div>
  )}

  <div class="dash-head">
    <AdminPageSwitcher current="recipes" />
    <a href="/admin/new" class="admin-btn admin-btn--primary">+ New Recipe</a>
  </div>

  <div class="dash-tabs" role="tablist">
    <button class="dash-tab dash-tab--active" data-tab="published" role="tab" aria-selected="true">
      Published <span class="dash-tab__count">{published.length}</span>
    </button>
    <button class="dash-tab" data-tab="drafts" role="tab" aria-selected="false">
      Drafts <span class="dash-tab__count">{drafts.length}</span>
    </button>
    <button class="dash-tab" data-tab="archived" role="tab" aria-selected="false">
      Archived <span class="dash-tab__count">{archived.length}</span>
    </button>
  </div>

  <!-- Published -->
  <div class="dash-panel" id="panel-published">
    {published.length === 0 ? (
      <div class="dash-empty">
        <p>No published recipes yet.</p>
        <p><a href="/admin/new">Add your first recipe →</a></p>
      </div>
    ) : (
      <ul class="dash-list" role="list">
        {published.map(r => (
          <li class="dash-row">
            <div class="dash-row__info">
              <span class="dash-row__title">{r.title}</span>
              <span class="dash-category-pill">{r.category}</span>
            </div>
            {r.pubDate && <span class="dash-row__date">{r.pubDate}</span>}
            <div class="dash-row__actions">
              <a href={`/recipes/${r.slug}`} target="_blank" rel="noopener" class="admin-btn admin-btn--ghost">View</a>
              <a href={`/admin/edit/${r.slug}?cat=${r.folderName}`} class="admin-btn admin-btn--secondary">Edit</a>
              <button type="button" class="admin-btn admin-btn--tertiary"
                data-action="archive" data-slug={r.slug} data-folder={r.folderName} data-archived="false">
                Archive
              </button>
              <button type="button" class="admin-btn admin-btn--danger"
                data-action="delete" data-slug={r.slug} data-folder={r.folderName}
                data-title={r.title} data-image={r.image ?? ''}>
                Delete
              </button>
            </div>
          </li>
        ))}
      </ul>
    )}
  </div>

  <!-- Drafts -->
  <div class="dash-panel" id="panel-drafts" hidden>
    {drafts.length === 0 ? (
      <div class="dash-empty"><p>No drafts.</p></div>
    ) : (
      <ul class="dash-list" role="list">
        {drafts.map(r => (
          <li class="dash-row">
            <div class="dash-row__info">
              <span class="dash-row__title">{r.title}</span>
              <span class="dash-category-pill">{r.category}</span>
              <span class="dash-status-pill dash-status-pill--draft">Draft</span>
            </div>
            {r.pubDate && <span class="dash-row__date">{r.pubDate}</span>}
            <div class="dash-row__actions">
              <a href={`/admin/edit/${r.slug}?cat=${r.folderName}`} class="admin-btn admin-btn--secondary">Edit</a>
              <button type="button" class="admin-btn admin-btn--tertiary"
                data-action="archive" data-slug={r.slug} data-folder={r.folderName} data-archived="false">
                Archive
              </button>
              <button type="button" class="admin-btn admin-btn--danger"
                data-action="delete" data-slug={r.slug} data-folder={r.folderName}
                data-title={r.title} data-image={r.image ?? ''}>
                Delete
              </button>
            </div>
          </li>
        ))}
      </ul>
    )}
  </div>

  <!-- Archived -->
  <div class="dash-panel" id="panel-archived" hidden>
    {archived.length === 0 ? (
      <div class="dash-empty"><p>Nothing archived.</p></div>
    ) : (
      <ul class="dash-list" role="list">
        {archived.map(r => (
          <li class="dash-row">
            <div class="dash-row__info">
              <span class="dash-row__title">{r.title}</span>
              <span class="dash-category-pill">{r.category}</span>
              <span class="dash-status-pill dash-status-pill--archived">Archived</span>
            </div>
            {r.pubDate && <span class="dash-row__date">{r.pubDate}</span>}
            <div class="dash-row__actions">
              <a href={`/admin/edit/${r.slug}?cat=${r.folderName}`} class="admin-btn admin-btn--secondary">Edit</a>
              <button type="button" class="admin-btn admin-btn--tertiary"
                data-action="archive" data-slug={r.slug} data-folder={r.folderName} data-archived="true">
                Unarchive
              </button>
              <button type="button" class="admin-btn admin-btn--danger"
                data-action="delete" data-slug={r.slug} data-folder={r.folderName}
                data-title={r.title} data-image={r.image ?? ''}>
                Delete
              </button>
            </div>
          </li>
        ))}
      </ul>
    )}
  </div>

  <!-- Delete confirmation modal -->
  <div class="modal-backdrop" id="delete-modal" hidden aria-modal="true" role="dialog" aria-labelledby="modal-heading">
    <div class="modal">
      <h2 class="modal-title" id="modal-heading">Delete Recipe?</h2>
      <p class="modal-body">
        "<span id="modal-recipe-title"></span>" will be permanently deleted from GitHub.
        This cannot be undone. Consider archiving instead if you might want it back.
      </p>
      <div class="modal-actions">
        <button type="button" id="modal-cancel" class="admin-btn admin-btn--secondary">Cancel</button>
        <button type="button" id="modal-confirm" class="admin-btn admin-btn--danger">Delete Permanently</button>
      </div>
    </div>
  </div>

</AdminLayout>

<style>
  .dash-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: var(--space-6);
    padding-bottom: var(--space-5);
    border-bottom: 2px solid rgba(121, 59, 2, 0.12);
  }

  .dash-head h1 { font-size: var(--text-3xl); }

  .dash-error {
    background: rgba(189, 8, 28, 0.06);
    border: 1px solid rgba(189, 8, 28, 0.25);
    border-radius: var(--radius-md);
    padding: var(--space-4) var(--space-5);
    margin-bottom: var(--space-6);
    color: #bd081c;
    font-size: var(--text-sm);
  }

  /* ── TABS ── */
  .dash-tabs {
    display: flex;
    border-bottom: 2px solid rgba(118, 130, 95, 0.15);
    margin-bottom: var(--space-6);
  }

  .dash-tab {
    background: none;
    border: none;
    border-bottom: 2px solid transparent;
    margin-bottom: -2px;
    padding: var(--space-3) var(--space-5);
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: var(--space-2);
    transition: color var(--transition-fast), border-color var(--transition-fast);
  }

  .dash-tab:hover { color: var(--color-text); }

  .dash-tab--active {
    color: var(--color-accent-3);
    border-bottom-color: var(--color-accent-3);
    font-weight: 500;
  }

  .dash-tab__count {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 20px;
    height: 20px;
    padding: 0 var(--space-1);
    background: rgba(118, 130, 95, 0.12);
    border-radius: 999px;
    font-size: var(--text-xs);
    color: var(--color-text-muted);
  }

  .dash-tab--active .dash-tab__count {
    background: rgba(121, 59, 2, 0.1);
    color: var(--color-accent-3);
  }

  /* ── LIST ── */
  .dash-list {
    list-style: none;
    padding: 0;
  }

  .dash-row {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    padding: var(--space-4) var(--space-2);
    border-bottom: 1px solid rgba(118, 130, 95, 0.1);
    transition: background var(--transition-fast);
  }

  .dash-row:hover { background: rgba(118, 130, 95, 0.03); }

  .dash-row__info {
    flex: 1;
    display: flex;
    align-items: center;
    gap: var(--space-3);
    min-width: 0;
  }

  .dash-row__title {
    font-family: var(--font-serif);
    font-size: var(--text-base);
    color: var(--color-text);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .dash-category-pill {
    display: inline-block;
    padding: 2px var(--space-2);
    background: rgba(118, 130, 95, 0.1);
    border: 1px solid rgba(118, 130, 95, 0.2);
    border-radius: 999px;
    font-size: var(--text-xs);
    color: var(--color-accent-1);
    white-space: nowrap;
    flex-shrink: 0;
  }

  .dash-status-pill {
    display: inline-block;
    padding: 2px var(--space-2);
    border-radius: 999px;
    font-size: var(--text-xs);
    white-space: nowrap;
    flex-shrink: 0;
  }

  .dash-status-pill--draft {
    background: rgba(189, 122, 87, 0.1);
    border: 1px solid rgba(189, 122, 87, 0.25);
    color: var(--color-accent-2);
  }

  .dash-status-pill--archived {
    background: rgba(100, 105, 106, 0.1);
    border: 1px solid rgba(100, 105, 106, 0.2);
    color: var(--color-text-muted);
  }

  .dash-row__date {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    font-style: italic;
    flex-shrink: 0;
  }

  .dash-row__actions {
    display: flex;
    gap: var(--space-1);
    flex-shrink: 0;
  }

  /* ── EMPTY STATE ── */
  .dash-empty {
    padding: var(--space-16) var(--space-6);
    text-align: center;
    border: 1px dashed rgba(118, 130, 95, 0.3);
    border-radius: var(--radius-md);
    color: var(--color-text-muted);
  }

  .dash-empty p { max-width: none; margin-bottom: var(--space-2); }
  .dash-empty a { color: var(--color-accent-2); }

  /* ── MODAL ── */
  .modal-backdrop {
    position: fixed;
    inset: 0;
    background: rgba(28, 19, 23, 0.5);
    z-index: 500;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-6);
  }

  .modal-backdrop[hidden] { display: none; }

  .modal {
    background: var(--color-bg);
    border-radius: var(--radius-lg);
    padding: var(--space-8);
    max-width: 480px;
    width: 100%;
    box-shadow: var(--shadow-lg);
  }

  .modal-title { font-size: var(--text-xl); margin-bottom: var(--space-4); }

  .modal-body {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    line-height: 1.6;
    margin-bottom: var(--space-6);
    max-width: none;
  }

  .modal-actions {
    display: flex;
    justify-content: flex-end;
    gap: var(--space-3);
  }

  /* ── MOBILE ── */
  @media (max-width: 640px) {
    .dash-row { flex-wrap: wrap; }
    .dash-row__info { width: 100%; }
    .dash-row__actions { width: 100%; justify-content: flex-end; }
    .dash-row__date { display: none; }
  }
</style>

<script>
  // ── TABS ──
  const tabs   = document.querySelectorAll<HTMLButtonElement>('.dash-tab');
  const panels = document.querySelectorAll<HTMLElement>('.dash-panel');

  tabs.forEach(tab => {
    tab.addEventListener('click', () => {
      tabs.forEach(t => { t.classList.remove('dash-tab--active'); t.setAttribute('aria-selected', 'false'); });
      tab.classList.add('dash-tab--active');
      tab.setAttribute('aria-selected', 'true');
      panels.forEach(p => { p.hidden = (p.id !== `panel-${tab.dataset.tab}`); });
    });
  });

  // ── DELETE MODAL ──
  const modal        = document.getElementById('delete-modal')!;
  const modalTitle   = document.getElementById('modal-recipe-title')!;
  const modalCancel  = document.getElementById('modal-cancel')!;
  const modalConfirm = document.getElementById('modal-confirm') as HTMLButtonElement;

  let pendingDelete: { slug: string; folder: string; image: string } | null = null;

  document.querySelectorAll<HTMLButtonElement>('[data-action="delete"]').forEach(btn => {
    btn.addEventListener('click', () => {
      pendingDelete = { slug: btn.dataset.slug!, folder: btn.dataset.folder!, image: btn.dataset.image! };
      modalTitle.textContent = btn.dataset.title!;
      modal.hidden = false;
    });
  });

  function closeModal() { modal.hidden = true; pendingDelete = null; }

  modalCancel.addEventListener('click', closeModal);
  modal.addEventListener('click', e => { if (e.target === modal) closeModal(); });
  document.addEventListener('keydown', e => { if (e.key === 'Escape' && !modal.hidden) closeModal(); });

  modalConfirm.addEventListener('click', async () => {
    if (!pendingDelete) return;
    modalConfirm.disabled = true;
    modalConfirm.textContent = 'Deleting…';

    try {
      const res = await fetch('/api/delete-recipe', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(pendingDelete),
      });
      if (!res.ok) {
        const data = await res.json().catch(() => ({}));
        throw new Error(data.error ?? 'Delete failed.');
      }
      document.querySelector<HTMLElement>(`[data-action="delete"][data-slug="${pendingDelete.slug}"]`)
        ?.closest('.dash-row')?.remove();
      closeModal();
    } catch (err: any) {
      alert(`Error: ${err.message}`);
    } finally {
      modalConfirm.disabled = false;
      modalConfirm.textContent = 'Delete Permanently';
    }
  });

  // ── ARCHIVE / UNARCHIVE ──
  document.querySelectorAll<HTMLButtonElement>('[data-action="archive"]').forEach(btn => {
    btn.addEventListener('click', async () => {
      const { slug, folder } = btn.dataset;
      const isCurrentlyArchived = btn.dataset.archived === 'true';
      btn.disabled = true;
      btn.textContent = isCurrentlyArchived ? 'Unarchiving…' : 'Archiving…';

      try {
        const res = await fetch('/api/archive-recipe', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ slug, folder, archived: !isCurrentlyArchived }),
        });
        if (!res.ok) {
          const data = await res.json().catch(() => ({}));
          throw new Error(data.error ?? 'Action failed.');
        }
        window.location.reload();
      } catch (err: any) {
        alert(`Error: ${err.message}`);
        btn.disabled = false;
        btn.textContent = isCurrentlyArchived ? 'Unarchive' : 'Archive';
      }
    });
  });
</script>