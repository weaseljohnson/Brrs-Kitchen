---
export const prerender = false;
import AdminLayout from '../../../layouts/AdminLayout.astro';
import yaml from 'js-yaml';

const { slug } = Astro.params;
const cat = Astro.url.searchParams.get('cat');

// cat is required to locate the file in GitHub
if (!cat) return Astro.redirect('/admin');

const GITHUB_TOKEN  = import.meta.env.GITHUB_TOKEN;
const GITHUB_OWNER  = import.meta.env.GITHUB_OWNER;
const GITHUB_REPO   = import.meta.env.GITHUB_REPO;
const GITHUB_BRANCH = import.meta.env.GITHUB_BRANCH;

const authHeader = {
  Authorization: `Bearer ${GITHUB_TOKEN}`,
  Accept: 'application/vnd.github+json',
};

let recipeData: Record<string, any> | null = null;
let fetchError: string | null = null;

try {
  const filePath = `content/recipes/${cat}/${slug}.md`;
  const url = `https://api.github.com/repos/${GITHUB_OWNER}/${GITHUB_REPO}/contents/${filePath}`;

  const res = await fetch(url, { headers: authHeader });
  if (!res.ok) throw new Error(`Recipe not found (${res.status})`);

  const fileData   = await res.json();
  const rawContent = Buffer.from(fileData.content, 'base64').toString('utf8');
  const match      = rawContent.match(/^---\r?\n([\s\S]*?)\r?\n---/);

  if (!match) throw new Error('Could not parse recipe frontmatter.');

  const fm   = yaml.load(match[1]) as Record<string, any>;
  recipeData = { ...fm, slug };
} catch (err: any) {
  fetchError = err.message;
}

const CATEGORIES = ['Desserts', 'Entrees', 'Sides', 'Drinks', 'Snacks', 'Basics'];
---

<AdminLayout title="New Recipe">

  {fetchError && (
    <div class="edit-error">
      ⚠️ Could not load recipe: {fetchError}
    </div>
  )}

  <div class="form-head">
    <div>
      <a href="/admin" class="back-link">← Dashboard</a>
      <h1>Edit Recipe</h1>
    </div>
    <div class="form-head-actions">
      <button type="button" id="draft-btn" class="admin-btn admin-btn--secondary">Save as Draft</button>
      <button type="button" id="submit-btn" class="admin-btn admin-btn--primary">Publish Recipe</button>
    </div>
  </div>

  <form id="recipe-form" novalidate>

    <!-- ── DETAILS ── -->
    <div class="admin-section">
      <h2 class="admin-section-title">Details</h2>

      <div class="admin-field">
        <label for="f-title" class="admin-label admin-label--required">Title</label>
        <input type="text" id="f-title" class="admin-input" placeholder="The Best Homemade Brownies" autocomplete="off" />
      </div>

      <input type="hidden" id="f-slug" />
    </div>

    <!-- ── CATEGORY & TIMES ── -->
    <div class="admin-section">
      <h2 class="admin-section-title">Category & Times</h2>
      <div class="admin-row admin-row--3">
        <div class="admin-field admin-field--no-margin">
          <label for="f-category" class="admin-label admin-label--required">Category</label>
          <input type="text" id="f-category" class="admin-input" list="category-options" placeholder="Desserts" autocomplete="off" />
          <datalist id="category-options">
            {CATEGORIES.map(c => <option value={c} />)}
          </datalist>
        </div>
        <div class="admin-field admin-field--no-margin">
          <label for="f-prep" class="admin-label">Prep Time</label>
          <input type="text" id="f-prep" class="admin-input" placeholder="35–40 min" />
        </div>
        <div class="admin-field admin-field--no-margin">
          <label for="f-cook" class="admin-label">Cook Time</label>
          <input type="text" id="f-cook" class="admin-input" placeholder="20–25 min" />
        </div>
      </div>
    </div>

    <!-- ── INTRO ── -->
    <div class="admin-section">
      <h2 class="admin-section-title">Intro</h2>
      <div class="admin-field admin-field--no-margin">
        <label for="f-intro" class="admin-label">Intro Text</label>
        <textarea id="f-intro" class="admin-textarea" rows="3" placeholder="A brief description shown on the recipe page and in cards..."></textarea>
        <span class="admin-hint">Add a fun description!</span>
      </div>
    </div>

    <!-- ── TAGS & DIETARY ── -->
    <div class="admin-section">
      <h2 class="admin-section-title">Tags & Dietary</h2>

      <div class="admin-field">
        <label class="admin-label">Personal Tags</label>
        <div class="admin-chip-row" id="tags-chip-row"></div>
        <div class="chip-add-row">
          <input type="text" id="f-tag-input" class="admin-input" placeholder="Hubby's Favorite" autocomplete="off" />
          <button type="button" id="add-tag-btn" class="admin-btn admin-btn--secondary">Add</button>
        </div>
        <span class="admin-hint">Press Enter or click Add.</span>
      </div>

      <hr class="admin-divider" />

      <div class="admin-field admin-field--no-margin">
        <label class="admin-label">Dietary Flags</label>
        <div class="admin-chip-row" id="dietary-chip-row"></div>
        <div class="chip-add-row">
          <input type="text" id="f-dietary-input" class="admin-input" list="dietary-options" placeholder="Gluten Free" autocomplete="off" />
          <datalist id="dietary-options">
            <option value="Gluten Free" />
            <option value="Dairy Free" />
            <option value="Vegan" />
            <option value="Vegetarian" />
            <option value="Nut Free" />
            <option value="Egg Free" />
            <option value="Keto" />
            <option value="Low Carb" />
          </datalist>
          <button type="button" id="add-dietary-btn" class="admin-btn admin-btn--secondary">Add</button>
        </div>
        <span class="admin-hint">Press Enter or click Add.</span>
      </div>
    </div>

    <!-- ── IMAGE ── -->
    <div class="admin-section">
      <h2 class="admin-section-title">Image</h2>
      <div class="img-upload-area" id="img-upload-area">
        <div class="img-preview-wrap" id="img-preview-wrap" hidden>
          <img id="img-preview" src="" alt="Recipe image preview" class="img-preview" />
          <button type="button" id="img-clear-btn" class="img-clear-btn">Remove</button>
        </div>
        <div class="img-placeholder" id="img-placeholder">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
            <rect x="3" y="3" width="18" height="18" rx="2"/>
            <circle cx="8.5" cy="8.5" r="1.5"/>
            <polyline points="21 15 16 10 5 21"/>
          </svg>
          <p>Drag & drop or <span class="img-browse-btn">browse</span></p>
          <span class="admin-hint">JPG or PNG · Stored at /public/images/recipes/</span>
        </div>
      </div>
      <input type="file" id="img-file-input" accept="image/jpeg,image/png" style="display:none" />
    </div>

    <!-- ── INGREDIENTS ── -->
    <div class="admin-section">
      <h2 class="admin-section-title">Ingredients</h2>

      <div class="admin-row admin-row--2" style="margin-bottom: var(--space-4);">
        <div class="admin-field admin-field--no-margin">
          <label class="admin-checkbox-row">
            <input type="checkbox" id="use-variants" class="admin-checkbox" />
            <span class="admin-checkbox-text">Multiple pan sizes or variants</span>
          </label>
        </div>
        <div class="admin-field admin-field--no-margin" id="use-groups-field">
          <label class="admin-checkbox-row">
            <input type="checkbox" id="use-groups" class="admin-checkbox" />
            <span class="admin-checkbox-text">Group ingredients by component</span>
          </label>
        </div>
      </div>

      <!-- Single pan (default) -->
      <div id="single-wrap">
        <div class="admin-row admin-row--2" style="margin-bottom: var(--space-5);">
          <div class="admin-field admin-field--no-margin">
            <label for="f-yield" class="admin-label">Yield</label>
            <input type="text" id="f-yield" class="admin-input" placeholder="16 brownies" />
          </div>
        </div>

        <!-- Flat list (no groups) -->
        <div id="single-flat">
          <div class="ing-col-headers">
            <span class="admin-label">Amount</span>
            <span class="admin-label">Ingredient</span>
          </div>
          <div id="single-ing-list"></div>
          <button type="button" id="add-single-ing-btn" class="admin-btn admin-btn--ghost"
            style="margin-top: var(--space-2);">+ Add Ingredient</button>
        </div>

        <!-- Grouped list (hidden by default) -->
        <div id="single-grouped" hidden>
          <div id="single-group-list"></div>
          <button type="button" id="add-single-group-btn" class="admin-btn admin-btn--secondary"
            style="margin-top: var(--space-2);">+ Add Group</button>
        </div>
      </div>

      <!-- Pan variants (hidden by default) -->
      <div id="variants-wrap" hidden>
        <div id="variants-list"></div>
        <button type="button" id="add-variant-btn" class="admin-btn admin-btn--secondary">+ Add Variant</button>
      </div>
    </div>

    <!-- ── DIRECTIONS ── -->
    <div class="admin-section">
      <h2 class="admin-section-title">Directions</h2>
      <div id="steps-list"></div>
      <button type="button" id="add-step-btn" class="admin-btn admin-btn--secondary" style="margin-top: var(--space-4);">+ Add Step</button>
    </div>

    <!-- ── NOTES ── -->
    <div class="admin-section">
      <h2 class="admin-section-title">Notes</h2>
      <div class="admin-field">
        <label class="admin-checkbox-row">
          <input type="checkbox" id="has-notes" class="admin-checkbox" />
          <span class="admin-checkbox-text">This recipe includes a notes section</span>
        </label>
      </div>
      <div id="notes-wrap" hidden>
        <div id="notes-list"></div>
        <button type="button" id="add-note-btn" class="admin-btn admin-btn--secondary" style="margin-top: var(--space-4);">+ Add Note</button>
        <span class="admin-hint" style="margin-top: var(--space-2); display: block;">Each note displays as a bullet point on the recipe page.</span>
      </div>
    </div>

    <!-- ── CREDIT ── -->
    <div class="admin-section">
      <h2 class="admin-section-title">Credit</h2>
      <div class="admin-field">
        <label class="admin-checkbox-row">
          <input type="checkbox" id="has-credit" class="admin-checkbox" />
          <span class="admin-checkbox-text">Credit another source for this recipe</span>
        </label>
      </div>
      <div id="credit-wrap" hidden>
        <div class="admin-row admin-row--2">
          <div class="admin-field admin-field--no-margin">
            <label for="f-credit-name" class="admin-label">Name</label>
            <input type="text" id="f-credit-name" class="admin-input" placeholder="Source or creator name" />
          </div>
          <div class="admin-field admin-field--no-margin">
            <label for="f-credit-url" class="admin-label">URL</label>
            <input type="url" id="f-credit-url" class="admin-input" placeholder="https://..." />
          </div>
        </div>
      </div>
    </div>

  </form>

  <script type="application/json" id="recipe-edit-data" set:html={JSON.stringify(recipeData)} />

</AdminLayout>

<style is:global>

  .edit-error {
    background: rgba(189, 8, 28, 0.06);
    border: 1px solid rgba(189, 8, 28, 0.25);
    border-radius: var(--radius-md);
    padding: var(--space-4) var(--space-5);
    margin-bottom: var(--space-6);
    color: #bd081c;
    font-size: var(--text-sm);
  }

    /* ── PAGE HEADER ── */
    .form-head {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: var(--space-4);
      margin-bottom: var(--space-8);
    }

    .form-head-actions {
      display: flex;
      gap: var(--space-3);
      align-items: center;
      flex-shrink: 0;
    }

    .back-link {
      display: inline-block;
      font-family: var(--font-sans);
      font-size: var(--text-sm);
      color: var(--color-text-muted);
      text-decoration: none;
      margin-bottom: var(--space-2);
      transition: color var(--transition-fast);
    }

    .back-link:hover { color: var(--color-accent-3); }

    .form-head h1 { font-size: var(--text-3xl); }

    /* ── CHIP ADD ROW ── */
    .chip-add-row {
      display: flex;
      gap: var(--space-2);
      align-items: center;
      margin-top: var(--space-2);
    }

    .chip-add-row .admin-input { max-width: 280px; }

    /* ── IMAGE UPLOAD ── */
    .img-upload-area {
      border: 2px dashed rgba(118, 130, 95, 0.3);
      border-radius: var(--radius-md);
      min-height: 160px;
      display: flex;
      align-items: center;
      justify-content: center;
      cursor: pointer;
      overflow: hidden;
      transition: border-color var(--transition-fast), background var(--transition-fast);
    }

    .img-upload-area:hover,
    .img-upload-area.is-drag-over {
      border-color: var(--color-accent-1);
      background: rgba(118, 130, 95, 0.03);
    }

    .img-placeholder {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: var(--space-2);
      color: var(--color-text-muted);
      text-align: center;
      padding: var(--space-8);
      pointer-events: none;
    }

    .img-placeholder p {
      font-size: var(--text-sm);
      max-width: none;
      margin: 0;
    }

    .img-browse-btn {
      color: var(--color-accent-2);
      text-decoration: underline;
      text-underline-offset: 2px;
      pointer-events: auto;
      cursor: pointer;
    }

    .img-preview-wrap { position: relative; width: 100%; }

    .img-preview {
      width: 100%;
      max-height: 300px;
      object-fit: cover;
      display: block;
    }

    .img-clear-btn {
      position: absolute;
      top: var(--space-3);
      right: var(--space-3);
      font-family: var(--font-sans);
      font-size: var(--text-xs);
      padding: var(--space-1) var(--space-3);
      background: rgba(28, 19, 23, 0.65);
      color: #fff;
      border: none;
      border-radius: var(--radius-sm);
      cursor: pointer;
      transition: background var(--transition-fast);
    }

    .img-clear-btn:hover { background: rgba(28, 19, 23, 0.85); }

    /* Image Preview Takeover */
    .img-upload-area.has-image {
      border-color: transparent;
      background: transparent;
      min-height: auto;
    }

    /* Force elements to actually disappear when the 'hidden' attribute is applied */
    .img-placeholder[hidden],
    .img-preview-wrap[hidden] {
      display: none !important;
    }

    /* ── INGREDIENT COLUMN HEADERS ── */
    .ing-col-headers,
    .variant-ing-headers {
      display: grid;
      grid-template-columns: 1fr 2fr;
      gap: var(--space-2);
      /* accounts for gap + 3 buttons width so headers align with inputs */
      padding-right: calc(var(--space-2) + 92px);
      margin-bottom: var(--space-2);
    }

    /* ── INGREDIENT ROWS ── */
    .ing-row {
      display: grid;
      grid-template-columns: 1fr 2fr auto;
      gap: var(--space-2);
      align-items: center;
      margin-bottom: var(--space-2);
    }

    /* ── INGREDIENT GROUP BLOCKS ── */
    .ing-group-block {
      border: 1px solid rgba(118, 130, 95, 0.2);
      border-radius: var(--radius-md);
      padding: var(--space-4) var(--space-5);
      margin-bottom: var(--space-4);
      background: rgba(118, 130, 95, 0.02);
    }

    .ing-group-head {
      display: flex;
      align-items: center;
      gap: var(--space-3);
      margin-bottom: var(--space-4);
    }

    .ing-group-head .ing-group-name {
      flex: 1;
    }

    /* ── VARIANT BLOCKS ── */
    .variant-block {
      border: 1px solid rgba(118, 130, 95, 0.2);
      border-radius: var(--radius-md);
      padding: var(--space-5) var(--space-6);
      margin-bottom: var(--space-4);
      background: rgba(118, 130, 95, 0.02);
  }

  .variant-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: var(--space-4);
    padding-bottom: var(--space-3);
    border-bottom: 1px solid rgba(118, 130, 95, 0.12);
  }

  .variant-head-label {
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    font-weight: 400;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .variant-meta {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-4);
    margin-bottom: var(--space-4);
  }

  /* ── STEP BLOCKS ── */
  .step-block {
    display: grid;
    grid-template-columns: 2rem 1fr auto;
    gap: var(--space-4);
    align-items: start;
    padding-bottom: var(--space-5);
    margin-bottom: var(--space-5);
    border-bottom: 1px solid rgba(118, 130, 95, 0.12);
  }

  .step-block:last-child {
    border-bottom: none;
    padding-bottom: 0;
    margin-bottom: 0;
  }

  .step-num {
    font-family: var(--font-serif);
    font-size: var(--text-xl);
    font-weight: 700;
    color: var(--color-accent-2);
    line-height: 2.5rem;
  }

  .step-fields {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .step-controls {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    padding-top: var(--space-1);
  }

  .note-entry {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: var(--space-2);
    align-items: center;
    margin-bottom: var(--space-2);
  }

  /* ── UNIVERSAL PADDING REDUCTIONS (Step 7) ── */
  .ing-group-block {
    padding: var(--space-3) var(--space-4); /* Reduced from space-4 space-5 */
  }

  .variant-block {
    padding: var(--space-4) var(--space-4); /* Reduced from space-5 space-6 */
  }

  .step-block {
    gap: var(--space-3); /* Micro-adjust gap between number and inputs */
  }

  /* ── MOBILE BREAKPOINT RESTRUCTURES (Steps 3, 4, 5) ── */
  @media (max-width: 768px) {
    
    /* Step 3: Stack Top Header cleanly */
    .form-head {
      flex-direction: column;
      align-items: stretch;
    }
    
    .form-head-actions {
      justify-content: flex-end;
    }

    /* Step 4: Stack Category and Times (targets your 3-col and 2-col grids) */
    .admin-row--3,
    .admin-row--2 {
      display: flex;
      flex-direction: column;
      gap: var(--space-4);
    }

    /* Step 5: Stack Ingredient Actions and Expand Inputs */
    .ing-row {
      display: flex;
      align-items: flex-start;
    }

    /* Give inputs max room */
    .ing-count { width: 35%; }
    .ing-item { width: 65%; flex-grow: 1; }

    /* Stack up/down arrows and X vertically */
    .ing-controls {
      flex-direction: column; 
      margin-left: auto;
    }

    /* Hide column headers on mobile as they no longer align with flex inputs */
    .ing-col-headers,
    .variant-ing-headers {
      display: none;
    }
  }

</style>

<script>
  import {
    slugify, makeIngRow, makeNoteEntry, makeVariantBlock, renumberVariants,
    makeIngredientGroupBlock, makeStepBlock, renumberSteps, addChip
  } from '../../../scripts/adminFormHelpers.js';

  // ── SLUG ──
  const titleInput = document.getElementById('f-title') as HTMLInputElement;
  const slugInput  = document.getElementById('f-slug')  as HTMLInputElement;
  let slugLocked   = true; // Always locked on edit — slug must never change

  titleInput.addEventListener('input', () => {
    if (!slugLocked) slugInput.value = slugify(titleInput.value);
  });

  // ── TAGS ──
  const tagsRow  = document.getElementById('tags-chip-row')!;
  const tagInput = document.getElementById('f-tag-input') as HTMLInputElement;

  function submitTag() {
    const v = tagInput.value.trim();
    if (!v) return;
    addChip(tagsRow, v, 'personal');
    tagInput.value = '';
    tagInput.focus();
  }
  document.getElementById('add-tag-btn')!.addEventListener('click', submitTag);
  tagInput.addEventListener('keydown', e => { if (e.key === 'Enter') { e.preventDefault(); submitTag(); } });

  // ── DIETARY ──
  const dietaryRow   = document.getElementById('dietary-chip-row')!;
  const dietaryInput = document.getElementById('f-dietary-input') as HTMLInputElement;

  function submitDietary() {
    const v = dietaryInput.value.trim();
    if (!v) return;
    addChip(dietaryRow, v, 'dietary');
    dietaryInput.value = '';
    dietaryInput.focus();
  }
  document.getElementById('add-dietary-btn')!.addEventListener('click', submitDietary);
  dietaryInput.addEventListener('keydown', e => { if (e.key === 'Enter') { e.preventDefault(); submitDietary(); } });

  // ── IMAGE ──
  const uploadArea  = document.getElementById('img-upload-area')!;
  const fileInput   = document.getElementById('img-file-input') as HTMLInputElement;
  const previewWrap = document.getElementById('img-preview-wrap')!;
  const previewImg  = document.getElementById('img-preview') as HTMLImageElement;
  const placeholder = document.getElementById('img-placeholder')!;
  let imageFile: File | null     = null;
  let existingImagePath: string | null = null; // populated by initEditMode

  function showPreview(file: File) {
    imageFile = file;
    const reader = new FileReader();
    reader.onload = e => {
      previewImg.src = (e.target as FileReader).result as string;
      previewWrap.hidden = false;
      placeholder.hidden = true;
      uploadArea.classList.add('has-image');
    };
    reader.readAsDataURL(file);
  }

  function clearImage() {
    imageFile = null;
    existingImagePath = null;
    fileInput.value = '';
    previewImg.src = '';
    previewWrap.hidden = true;
    placeholder.hidden = false;
    uploadArea.classList.remove('has-image');
  }

  uploadArea.addEventListener('click', () => fileInput.click());
  fileInput.addEventListener('change', () => { if (fileInput.files![0]) showPreview(fileInput.files![0]); });
  document.getElementById('img-clear-btn')!.addEventListener('click', e => {
    e.stopPropagation();
    clearImage();
  });
  uploadArea.addEventListener('dragover', e => { e.preventDefault(); uploadArea.classList.add('is-drag-over'); });
  uploadArea.addEventListener('dragleave', () => uploadArea.classList.remove('is-drag-over'));
  uploadArea.addEventListener('drop', e => {
    e.preventDefault();
    uploadArea.classList.remove('is-drag-over');
    const f = (e as DragEvent).dataTransfer?.files[0];
    if (f?.type.startsWith('image/')) showPreview(f);
  });

  // ── INGREDIENTS ──
  const useVariants     = document.getElementById('use-variants')     as HTMLInputElement;
  const useGroups       = document.getElementById('use-groups')        as HTMLInputElement;
  const useGroupsField  = document.getElementById('use-groups-field')!;
  const singleWrap      = document.getElementById('single-wrap')!;
  const singleFlat      = document.getElementById('single-flat')!;
  const singleGrouped   = document.getElementById('single-grouped')!;
  const variantsWrap    = document.getElementById('variants-wrap')!;
  const singleIngList   = document.getElementById('single-ing-list')!;
  const singleGroupList = document.getElementById('single-group-list')!;
  const variantsList    = document.getElementById('variants-list')!;

  useVariants.addEventListener('change', () => {
    const on = useVariants.checked;
    singleWrap.hidden    = on;
    variantsWrap.hidden  = !on;
    useGroupsField.hidden = on;
    if (on && variantsList.children.length === 0) {
      variantsList.appendChild(makeVariantBlock(0));
    }
  });

  useGroups.addEventListener('change', () => {
    const on = useGroups.checked;
    singleFlat.hidden    = on;
    singleGrouped.hidden = !on;
    if (on && singleGroupList.children.length === 0) {
      const firstGroup = makeIngredientGroupBlock();
      const groupList  = firstGroup.querySelector('.ing-group-list')!;
      groupList.innerHTML = '';
      while (singleIngList.firstElementChild) {
        groupList.appendChild(singleIngList.firstElementChild);
      }
      if (groupList.children.length === 0) groupList.appendChild(makeIngRow());
      singleGroupList.appendChild(firstGroup);
    } else if (!on) {
      singleGroupList.querySelectorAll('.ing-row').forEach(row => singleIngList.appendChild(row));
      singleGroupList.innerHTML = '';
      if (singleIngList.children.length === 0) singleIngList.appendChild(makeIngRow());
    }
  });

  document.getElementById('add-single-ing-btn')!.addEventListener('click', () => singleIngList.appendChild(makeIngRow()));
  document.getElementById('add-single-group-btn')!.addEventListener('click', () => singleGroupList.appendChild(makeIngredientGroupBlock()));
  document.getElementById('add-variant-btn')!.addEventListener('click', () => variantsList.appendChild(makeVariantBlock(variantsList.children.length)));

  // ── STEPS ──
  const stepsList = document.getElementById('steps-list')!;

  document.getElementById('add-step-btn')!.addEventListener('click', () => {
    stepsList.appendChild(makeStepBlock(stepsList.children.length));
  });

  // ── NOTES ──
  const hasNotesChk = document.getElementById('has-notes')  as HTMLInputElement;
  const notesWrap   = document.getElementById('notes-wrap')!;
  const notesList   = document.getElementById('notes-list')!;

  hasNotesChk.addEventListener('change', () => {
    notesWrap.hidden = !hasNotesChk.checked;
    if (hasNotesChk.checked && notesList.children.length === 0) {
      notesList.appendChild(makeNoteEntry());
    }
  });

  document.getElementById('add-note-btn')!.addEventListener('click', () => notesList.appendChild(makeNoteEntry('')));

  // ── CREDIT ──
  const hasCreditChk = document.getElementById('has-credit') as HTMLInputElement;
  const creditWrap   = document.getElementById('credit-wrap')!;
  hasCreditChk.addEventListener('change', () => { creditWrap.hidden = !hasCreditChk.checked; });

  // ── INIT EDIT MODE ──
  function initEditMode(data: Record<string, any>) {
    // Slug — lock it; changing slug on edit would orphan the old file
    slugInput.value = data.slug ?? '';
    slugLocked = true;

    // Basic fields
    (document.getElementById('f-title')    as HTMLInputElement).value = data.title    ?? '';
    (document.getElementById('f-category') as HTMLInputElement).value = data.category ?? '';
    (document.getElementById('f-prep')     as HTMLInputElement).value = data.prepTime ?? '';
    (document.getElementById('f-cook')     as HTMLInputElement).value = data.cookTime ?? '';
    (document.getElementById('f-intro')    as HTMLTextAreaElement).value = data.intro ?? '';

    // Tags + dietary
    (data.tags    ?? []).forEach((t: string) => addChip(tagsRow,    t, 'personal'));
    (data.dietary ?? []).forEach((t: string) => addChip(dietaryRow, t, 'dietary'));

    // Existing image — show preview using the public URL path
    if (data.image) {
      existingImagePath = data.image;
      previewImg.src    = data.image;
      previewWrap.hidden = false;
      placeholder.hidden = true;
      uploadArea.classList.add('has-image');
    }

    // Ingredients
    if (data.panVariants?.length) {
      useVariants.checked = true;
      useVariants.dispatchEvent(new Event('change'));
      variantsList.innerHTML = '';

      data.panVariants.forEach((variant: any, i: number) => {
        const block = makeVariantBlock(i);
        (block.querySelector('.variant-label') as HTMLInputElement).value = variant.label ?? '';
        (block.querySelector('.variant-yield') as HTMLInputElement).value = variant.yield ?? '';
        const ingList = block.querySelector('.variant-ing-list')!;
        ingList.innerHTML = '';
        (variant.ingredients ?? []).forEach((ing: any) => {
          ingList.appendChild(makeIngRow(ing.count ?? '', ing.item ?? ''));
        });
        variantsList.appendChild(block);
      });
      renumberVariants();

    } else if (data.ingredients?.length) {
      const isGrouped = 'groupName' in data.ingredients[0];

      if (isGrouped) {
        useGroups.checked = true;
        useGroups.dispatchEvent(new Event('change'));
        singleGroupList.innerHTML = '';

        data.ingredients.forEach((group: any) => {
          const block = makeIngredientGroupBlock();
          (block.querySelector('.ing-group-name') as HTMLInputElement).value = group.groupName ?? '';
          const groupList = block.querySelector('.ing-group-list')!;
          groupList.innerHTML = '';
          (group.ingredients ?? []).forEach((ing: any) => {
            groupList.appendChild(makeIngRow(ing.count ?? '', ing.item ?? ''));
          });
          singleGroupList.appendChild(block);
        });

      } else {
        singleIngList.innerHTML = '';
        data.ingredients.forEach((ing: any) => {
          singleIngList.appendChild(makeIngRow(ing.count ?? '', ing.item ?? ''));
        });
      }

      if (data.yield) {
        (document.getElementById('f-yield') as HTMLInputElement).value = data.yield;
      }
    }

    // Directions
    stepsList.innerHTML = '';
    (data.directions ?? []).forEach((step: any, i: number) => {
      const block = makeStepBlock(i);
      (block.querySelector('.step-title-input') as HTMLInputElement).value  = step.title ?? '';
      (block.querySelector('.step-body-input')  as HTMLTextAreaElement).value = step.body ?? '';
      stepsList.appendChild(block);
    });
    if (stepsList.children.length === 0) stepsList.appendChild(makeStepBlock(0));

    // Notes
    if (data.notes?.length) {
      hasNotesChk.checked = true;
      notesWrap.hidden    = false;
      notesList.innerHTML = '';
      data.notes.forEach((note: string) => notesList.appendChild(makeNoteEntry(note)));
    }

    // Credit
    if (data.credit?.name) {
      hasCreditChk.checked = true;
      creditWrap.hidden    = false;
      (document.getElementById('f-credit-name') as HTMLInputElement).value = data.credit.name;
      (document.getElementById('f-credit-url')  as HTMLInputElement).value = data.credit.url ?? '';
    }
  }

  // ── COLLECT PAYLOAD ──
  function readImageAsBase64(file: File): Promise<{ data: string; ext: string }> {
    return new Promise((resolve, reject) => {
      const reader = new FileReader();
      reader.onload  = e => {
        const base64 = ((e.target as FileReader).result as string).split(',')[1];
        const ext    = file.name.split('.').pop()!.toLowerCase();
        resolve({ data: base64, ext });
      };
      reader.onerror = () => reject(new Error('Failed to read image file.'));
      reader.readAsDataURL(file);
    });
  }

  function collectPayload() {
    const usingVariants = useVariants.checked;
    const usingGroups   = useGroups.checked;

    const payload: Record<string, any> = {
      title:    (document.getElementById('f-title')    as HTMLInputElement).value.trim(),
      slug:     (document.getElementById('f-slug')     as HTMLInputElement).value.trim(),
      category: (document.getElementById('f-category') as HTMLInputElement).value.trim(),
      prepTime: (document.getElementById('f-prep')     as HTMLInputElement).value.trim() || undefined,
      cookTime: (document.getElementById('f-cook')     as HTMLInputElement).value.trim() || undefined,
      intro:    (document.getElementById('f-intro')    as HTMLTextAreaElement).value.trim() || undefined,
      tags:     [...tagsRow.querySelectorAll<HTMLElement>('.admin-chip')].map(c => c.dataset.value!),
      dietary:  [...dietaryRow.querySelectorAll<HTMLElement>('.admin-chip')].map(c => c.dataset.value!),
      notes: hasNotesChk.checked
        ? [...notesList.querySelectorAll<HTMLInputElement>('.note-input')]
            .map(el => el.value.trim()).filter(Boolean)
        : undefined,
      credit: hasCreditChk.checked ? {
        name: (document.getElementById('f-credit-name') as HTMLInputElement).value.trim(),
        url:  (document.getElementById('f-credit-url')  as HTMLInputElement).value.trim(),
      } : undefined,
      // Preserve existing image path if no new image was uploaded
      existingImagePath: !imageFile && existingImagePath ? existingImagePath : undefined,
    };

    if (usingVariants) {
      payload.panVariants = [...variantsList.querySelectorAll<HTMLElement>('.variant-block')].map((block, i) => ({
        id:    slugify((block.querySelector('.variant-label') as HTMLInputElement).value) || `variant-${i + 1}`,
        label: (block.querySelector('.variant-label') as HTMLInputElement).value.trim(),
        yield: (block.querySelector('.variant-yield') as HTMLInputElement).value.trim() || undefined,
        ingredients: [...block.querySelectorAll<HTMLElement>('.ing-row')]
          .map(row => ({
            count: (row.querySelector('.ing-count') as HTMLInputElement).value.trim() || undefined,
            item:  (row.querySelector('.ing-item')  as HTMLInputElement).value.trim(),
          }))
          .filter(ing => ing.item),
      }));
    } else if (usingGroups) {
      payload.yield = (document.getElementById('f-yield') as HTMLInputElement).value.trim() || undefined;
      payload.ingredients = [...singleGroupList.querySelectorAll<HTMLElement>('.ing-group-block')].map(block => ({
        groupName: (block.querySelector('.ing-group-name') as HTMLInputElement).value.trim() || 'Ingredients',
        ingredients: [...block.querySelectorAll<HTMLElement>('.ing-row')]
          .map(row => ({
            count: (row.querySelector('.ing-count') as HTMLInputElement).value.trim() || undefined,
            item:  (row.querySelector('.ing-item')  as HTMLInputElement).value.trim(),
          }))
          .filter(ing => ing.item),
      }));
    } else {
      payload.yield = (document.getElementById('f-yield') as HTMLInputElement).value.trim() || undefined;
      payload.ingredients = [...singleIngList.querySelectorAll<HTMLElement>('.ing-row')]
        .map(row => ({
          count: (row.querySelector('.ing-count') as HTMLInputElement).value.trim() || undefined,
          item:  (row.querySelector('.ing-item')  as HTMLInputElement).value.trim(),
        }))
        .filter(ing => ing.item);
    }

    payload.directions = [...stepsList.querySelectorAll<HTMLElement>('.step-block')]
      .map(block => ({
        title: (block.querySelector('.step-title-input') as HTMLInputElement).value.trim(),
        body:  (block.querySelector('.step-body-input')  as HTMLTextAreaElement).value.trim(),
      }))
      .filter(s => s.title || s.body);

    return payload;
  }

  // ── SUBMIT ──
  async function submitRecipe(isDraft: boolean) {
    const payload = collectPayload();
    payload.draft = isDraft;

    if (imageFile) {
      try {
        payload.image = await readImageAsBase64(imageFile);
      } catch {
        alert('Failed to process the selected image file.');
        return;
      }
    }

    try {
      const res  = await fetch('/api/save-recipe', {
        method:  'POST',
        headers: { 'Content-Type': 'application/json' },
        body:    JSON.stringify(payload),
      });
      const data = await res.json();

      if (!res.ok) {
        const msg = data.errors?.join('\n') ?? data.error ?? 'Unknown error.';
        alert(`Save failed:\n\n${msg}`);
        return;
      }

      alert('Recipe updated! It will be live after Vercel rebuilds (~30–60 seconds).');
      window.location.href = '/admin';
    } catch (err: any) {
      alert(`Network error: ${err.message}`);
    }
  }

  document.getElementById('submit-btn')!.addEventListener('click', () => submitRecipe(false));
  document.getElementById('draft-btn')!.addEventListener('click',  () => submitRecipe(true));

  // ── BOOT: read data bridge and populate form ──
  const dataEl = document.getElementById('recipe-edit-data');
  if (dataEl) {
    try {
      const data = JSON.parse(dataEl.textContent ?? '{}');
      if (data) initEditMode(data);
    } catch {
      console.error('Failed to parse recipe edit data.');
    }
  }
</script>