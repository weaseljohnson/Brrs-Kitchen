---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const allRecipes = await getCollection('recipes');

// Latest recipes — sort by pubDate if present, otherwise take last N added
const latestRecipes = [...allRecipes]
  .sort((a, b) => {
    const dateA = a.data.pubDate ? new Date(a.data.pubDate).getTime() : 0;
    const dateB = b.data.pubDate ? new Date(b.data.pubDate).getTime() : 0;
    return dateB - dateA;
  })
  .slice(0, 3);

const categoryTiles = [
  { label: 'Mains',    href: '/recipes/mains',    emoji: '🍽️' },
  { label: 'Desserts', href: '/recipes/desserts',  emoji: '🍰' },
  { label: 'Sides',    href: '/recipes/sides',     emoji: '🥗' },
  { label: 'Drinks',   href: '/recipes/drinks',    emoji: '🥤' },
  { label: 'Snacks',   href: '/recipes/snacks',    emoji: '🧀' },
];
---

<Layout title="Home">
  <main class="home-page">

    <!-- ── CATEGORY TILES ── -->
    <section class="category-section">
      <div class="container">
        <ul class="category-tiles" role="list">
          {categoryTiles.map(tile => (
            <li>
              <a href={tile.href} class="category-tile">
                <span class="category-tile__emoji" aria-hidden="true">{tile.emoji}</span>
                <span class="category-tile__label">{tile.label}</span>
              </a>
            </li>
          ))}
        </ul>
      </div>
    </section>

    <!-- ── MAIN CONTENT ── -->
    <section class="home-content">
      <div class="container home-content__inner">

        <!-- Latest Recipes — left 2/3 -->
        <div class="latest-recipes">
          <h2 class="section-heading">Latest Recipes</h2>
          {latestRecipes.length === 0 ? (
            <p class="empty-state">No recipes yet — check back soon.</p>
          ) : (
            <ul class="recipe-list" role="list">
              {latestRecipes.map(recipe => (
                <li>
                  <a href={`/recipes/${recipe.id.split('/').pop()}`} class="recipe-card">
                    <div class="recipe-card__image-placeholder" aria-hidden="true"></div>
                    <div class="recipe-card__body">
                      <div class="recipe-card__meta">
                        <span class="recipe-card__category">{recipe.data.category}</span>
                      </div>
                      <h3 class="recipe-card__title">{recipe.data.title}</h3>
                      <div class="recipe-card__stats">
                        {recipe.data.prepTime && (
                          <span class="recipe-card__stat">Prep: {recipe.data.prepTime}</span>
                        )}
                        {recipe.data.cookTime && (
                          <span class="recipe-card__stat">Cook: {recipe.data.cookTime}</span>
                        )}
                      </div>
                    </div>
                  </a>
                </li>
              ))}
            </ul>
          )}
        </div>

        <!-- About blurb — right 1/3 -->
        <aside class="about-blurb">
          <div class="about-blurb__inner">
            <p class="about-blurb__greeting">Hello, I'm Brr.</p>
            <p class="about-blurb__placeholder">
              This space is coming soon — Brianna will fill this in with her own words.
            </p>
            <a href="/about" class="about-blurb__link">Learn more →</a>
          </div>
        </aside>

      </div>
    </section>

  </main>
</Layout>

<style>
  .home-page {
    padding-bottom: var(--space-20);
  }

  /* ── CATEGORY TILES ── */
  .category-section {
    padding: var(--space-10) 0;
  }

  .category-tiles {
    display: flex;
    gap: var(--space-4);
    list-style: none;
    padding: 0;
    margin: 0;
    flex-wrap: wrap;
  }

  .category-tile {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--space-3);
    width: 140px;
    height: 140px;
    background: rgba(118, 130, 95, 0.07);
    border: 1px solid rgba(118, 130, 95, 0.18);
    border-radius: var(--radius-lg);
    text-decoration: none;
    color: var(--color-text);
    transition: background var(--transition-fast), border-color var(--transition-fast), transform var(--transition-fast);
  }

  .category-tile:hover {
    background: rgba(118, 130, 95, 0.14);
    border-color: rgba(118, 130, 95, 0.35);
    transform: translateY(-2px);
  }

  .category-tile__emoji {
    font-size: 2rem;
    line-height: 1;
  }

  .category-tile__label {
    font-family: var(--font-serif);
    font-size: var(--text-sm);
    font-weight: 700;
  }

  /* ── HOME CONTENT GRID ── */
  .home-content {
    padding-top: var(--space-12);
  }

  .home-content__inner {
    display: grid;
    grid-template-columns: 2fr 1fr;
    gap: var(--space-12);
    align-items: start;
  }

  /* ── SECTION HEADING ── */
  .section-heading {
    font-size: var(--text-2xl);
    margin-bottom: var(--space-6);
    padding-bottom: var(--space-3);
    border-bottom: 2px solid rgba(121, 59, 2, 0.12);
  }

  /* ── RECIPE LIST ── */
  .recipe-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .recipe-card {
    display: flex;
    flex-direction: column;
    border: 1px solid rgba(118, 130, 95, 0.2);
    border-radius: var(--radius-md);
    text-decoration: none;
    color: var(--color-text);
    overflow: hidden;
    transition: border-color var(--transition-fast), transform var(--transition-fast), box-shadow var(--transition-fast);
  }

  .recipe-card:hover {
    border-color: rgba(118, 130, 95, 0.4);
    transform: translateY(-2px);
    box-shadow: var(--shadow-md);
  }

  .recipe-card__image-placeholder {
    width: 100%;
    aspect-ratio: 16 / 7;
    background: rgba(118, 130, 95, 0.08);
    border-bottom: 1px solid rgba(118, 130, 95, 0.12);
  }

  .recipe-card__body {
    padding: var(--space-5) var(--space-6);
  }

  .recipe-card__meta {
    margin-bottom: var(--space-2);
  }

  .recipe-card__category {
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    font-weight: 200;
    font-style: italic;
    color: var(--color-accent-2);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .recipe-card__title {
    font-family: var(--font-serif);
    font-size: var(--text-xl);
    font-weight: 700;
    margin-bottom: var(--space-3);
    line-height: 1.3;
  }

  .recipe-card__stats {
    display: flex;
    gap: var(--space-4);
  }

  .recipe-card__stat {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    font-style: italic;
    font-weight: 200;
  }

  .empty-state {
    color: var(--color-text-muted);
    font-style: italic;
  }

  /* ── ABOUT BLURB ── */
  .about-blurb__inner {
    background: rgba(222, 124, 90, 0.06);
    border: 1px solid rgba(222, 124, 90, 0.2);
    border-radius: var(--radius-lg);
    padding: var(--space-8) var(--space-6);
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .about-blurb__greeting {
    font-family: var(--font-serif);
    font-size: var(--text-2xl);
    font-weight: 700;
    color: var(--color-text);
    max-width: none;
  }

  .about-blurb__placeholder {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    font-style: italic;
    line-height: 1.6;
  }

  .about-blurb__link {
    font-size: var(--text-sm);
    color: var(--color-accent-2);
    text-decoration: none;
    font-weight: 400;
    transition: color var(--transition-fast);
  }

  .about-blurb__link:hover {
    color: var(--color-accent-3);
  }

  /* ── RESPONSIVE ── */
  @media (max-width: 768px) {
    .home-content__inner {
      grid-template-columns: 1fr;
    }

    .category-tiles {
      justify-content: center;
    }

    .category-tile {
      width: 120px;
      height: 120px;
    }
  }
</style>