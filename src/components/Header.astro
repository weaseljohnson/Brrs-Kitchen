---
const navItems = [
  {
    label: 'Recipes',
    href: '/recipes',
    dropdown: {
      columns: [
        {
          heading: 'By Type',
          links: [
            { label: 'Mains', href: '/recipes/mains' },
            { label: 'Desserts', href: '/recipes/desserts' },
            { label: 'Sides', href: '/recipes/sides' },
            { label: 'Drinks', href: '/recipes/drinks' },
            { label: 'Snacks', href: '/recipes/snacks' },
          ],
        },
        {
          heading: 'By Cuisine',
          links: [
            { label: 'Italian', href: '/recipes/cuisine/italian' },
            { label: 'Mexican', href: '/recipes/cuisine/mexican' },
            { label: 'Asian', href: '/recipes/cuisine/asian' },
            { label: 'American', href: '/recipes/cuisine/american' },
          ],
        },
        {
          heading: 'Dietary',
          links: [
            { label: 'Dairy Free', href: '/recipes/dietary/dairy-free' },
            { label: 'Gluten Free', href: '/recipes/dietary/gluten-free' },
            { label: 'Vegan', href: '/recipes/dietary/vegan' },
            { label: 'Vegetarian', href: '/recipes/dietary/vegetarian' },
          ],
        },
        {
          heading: 'Favorites',
          links: [
            { label: "Hubby's Favorites", href: '/recipes/tags/hubby-favorite' },
            { label: "Kid's Favorites", href: '/recipes/tags/kid-favorite' },
          ],
        },
      ],
    },
  },
  {
    label: 'Cooking Essentials',
    href: '/essentials',
    dropdown: {
      columns: [
        {
          heading: 'Dairy & Fats',
          links: [
            { label: 'Ricotta', href: '/essentials/ricotta' },
            { label: 'Clarified Butter', href: '/essentials/clarified-butter' },
            { label: 'Buttermilk', href: '/essentials/buttermilk' },
          ],
        },
        {
          heading: 'Sauces & Spices',
          links: [
            { label: 'Spice Mixes', href: '/essentials/spice-mixes' },
            { label: 'Sauces', href: '/essentials/sauces' },
          ],
        },
      ],
    },
  },
  {
    label: 'Cooking Fundamentals',
    href: '/fundamentals',
    dropdown: {
      columns: [
        {
          heading: 'Knife Skills',
          links: [
            { label: 'Basic Cuts', href: '/fundamentals/knife-skills/basic-cuts' },
            { label: 'Chopping Vegetables', href: '/fundamentals/knife-skills/chopping' },
          ],
        },
        {
          heading: 'Techniques',
          links: [
            { label: 'Sautéing', href: '/fundamentals/techniques/saute' },
            { label: 'Braising', href: '/fundamentals/techniques/braise' },
          ],
        },
      ],
    },
  },
  { label: 'Glossary', href: '/glossary' },
  { label: 'About', href: '/about' },
];
---

<header class="site-header">
  <div class="header-inner">

    <!-- Logo -->
    <a href="/" class="site-logo" aria-label="Brr's Kitchen home">
      Brr's Kitchen
    </a>

    <!-- Search -->
    <div class="header-search">
      <span class="search-icon" aria-hidden="true">
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
          <circle cx="6.5" cy="6.5" r="5" stroke="currentColor" stroke-width="1.5"/>
          <line x1="10.5" y1="10.5" x2="14.5" y2="14.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
      </span>
      <input
        type="search"
        class="search-input"
        placeholder="Search recipes…"
        aria-label="Search recipes"
        disabled
      />
    </div>

    <!-- Mobile menu toggle -->
    <button class="mobile-menu-toggle" aria-label="Open menu" aria-expanded="false" aria-controls="primary-nav">
      <span class="hamburger-bar"></span>
      <span class="hamburger-bar"></span>
      <span class="hamburger-bar"></span>
    </button>

    <!-- Primary nav -->
    <nav class="primary-nav" id="primary-nav" aria-label="Primary navigation">
      <ul class="nav-list" role="list">
        {navItems.map(item => (
          <li class={`nav-item${item.dropdown ? ' nav-item--has-dropdown' : ''}`}>
            {item.dropdown ? (
              <button
                class="nav-link nav-link--toggle"
                aria-expanded="false"
                aria-haspopup="true"
              >
                {item.label}
                <svg class="nav-chevron" width="10" height="6" viewBox="0 0 10 6" fill="none" aria-hidden="true">
                  <path d="M1 1l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </button>
            ) : (
              <a class="nav-link" href={item.href}>{item.label}</a>
            )}

            {item.dropdown && (
              <div class="dropdown" role="region">
                <div class="dropdown-inner">
                  {item.dropdown.columns.map(col => (
                    <div class="dropdown-col">
                      <p class="dropdown-heading">{col.heading}</p>
                      <ul role="list">
                        {col.links.map(link => (
                          <li>
                            <a class="dropdown-link" href={link.href}>{link.label}</a>
                          </li>
                        ))}
                      </ul>
                    </div>
                  ))}
                </div>
              </div>
            )}
          </li>
        ))}
      </ul>
    </nav>

  </div>
</header>

<style>
  /* ── HEADER SHELL ── */
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: var(--color-bg);
    border-bottom: 1px solid rgba(118, 130, 95, 0.2);
  }

  .header-inner {
    max-width: var(--max-width-content);
    margin-inline: auto;
    padding-inline: var(--space-6);
    height: 64px;
    display: flex;
    align-items: center;
    gap: var(--space-6);
  }

  /* ── LOGO ── */
  .site-logo {
    font-family: var(--font-serif);
    font-size: var(--text-xl);
    font-weight: 700;
    color: var(--color-text);
    text-decoration: none;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .site-logo:hover {
    color: var(--color-accent-3);
  }

  /* ── SEARCH ── */
  .header-search {
    flex: 1;
    max-width: 420px;
    position: relative;
    display: flex;
    align-items: center;
  }

  .search-icon {
    position: absolute;
    left: var(--space-3);
    color: var(--color-text-muted);
    display: flex;
    align-items: center;
    pointer-events: none;
  }

  .search-input {
    width: 100%;
    background: rgba(118, 130, 95, 0.08);
    border: 1px solid rgba(118, 130, 95, 0.2);
    border-radius: var(--radius-lg);
    padding: var(--space-2) var(--space-4) var(--space-2) var(--space-8);
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    color: var(--color-text);
    transition: border-color var(--transition-fast), background var(--transition-fast);
    cursor: not-allowed;
  }

  .search-input::placeholder {
    color: var(--color-text-muted);
  }

  /* ── NAV ── */
  .primary-nav {
    margin-left: auto;
  }

  .nav-list {
    display: flex;
    align-items: center;
    gap: var(--space-1);
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .nav-item {
    position: relative;
  }

  .nav-link {
    display: flex;
    align-items: center;
    gap: var(--space-1);
    padding: var(--space-2) var(--space-3);
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    font-weight: 400;
    color: var(--color-text);
    text-decoration: none;
    border-radius: var(--radius-sm);
    border: none;
    background: none;
    cursor: pointer;
    white-space: nowrap;
    transition: color var(--transition-fast), background var(--transition-fast);
  }

  .nav-link:hover {
    color: var(--color-accent-3);
    background: rgba(121, 59, 2, 0.06);
  }

  .nav-chevron {
    transition: transform var(--transition-fast);
    flex-shrink: 0;
  }

  /* ── DROPDOWN ── */
  .dropdown {
    display: none;
    position: absolute;
    top: calc(100% + var(--space-2));
    left: 50%;
    transform: translateX(-50%);
    background: var(--color-bg);
    border: 1px solid rgba(118, 130, 95, 0.2);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-lg);
    z-index: 200;
    min-width: 480px;
  }

  .dropdown-inner {
    display: flex;
    gap: var(--space-8);
    padding: var(--space-6);
  }

  .dropdown-col {
    min-width: 120px;
  }

  .dropdown-heading {
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    font-weight: 200;
    font-style: italic;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: var(--space-3);
    max-width: none;
  }

  .dropdown-col ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .dropdown-link {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    color: var(--color-text);
    text-decoration: none;
    transition: color var(--transition-fast);
  }

  .dropdown-link:hover {
    color: var(--color-accent-2);
  }

  /* Desktop: show dropdown on hover */
  @media (hover: hover) {
    .nav-item--has-dropdown:hover .dropdown {
      display: block;
    }

    .nav-item--has-dropdown:hover .nav-chevron {
      transform: rotate(180deg);
    }
  }

  /* ── MOBILE TOGGLE ── */
  .mobile-menu-toggle {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: var(--space-2);
    margin-left: auto;
  }

  .hamburger-bar {
    display: block;
    width: 22px;
    height: 2px;
    background: var(--color-text);
    border-radius: 2px;
    transition: transform var(--transition-fast), opacity var(--transition-fast);
  }

  /* ── MOBILE LAYOUT ── */
  @media (max-width: 768px) {
    .mobile-menu-toggle {
      display: flex;
    }

    .primary-nav {
      display: none;
      position: fixed;
      inset: 64px 0 0 0;
      background: var(--color-bg);
      overflow-y: auto;
      padding: var(--space-6);
      border-top: 1px solid rgba(118, 130, 95, 0.2);
      margin-left: 0;
    }

    .primary-nav.is-open {
      display: block;
    }

    .nav-list {
      flex-direction: column;
      align-items: flex-start;
      gap: 0;
    }

    .nav-item {
      width: 100%;
      border-bottom: 1px solid rgba(118, 130, 95, 0.1);
    }

    .nav-link {
      width: 100%;
      justify-content: space-between;
      padding: var(--space-4) 0;
      font-size: var(--text-base);
    }

    .dropdown {
      position: static;
      transform: none;
      box-shadow: none;
      border: none;
      border-radius: 0;
      min-width: 0;
      width: 100%;
    }

    .dropdown-inner {
      flex-direction: column;
      gap: var(--space-6);
      padding: 0 0 var(--space-4) var(--space-4);
    }

    /* Mobile: show dropdown on toggle (JS controlled) */
    .nav-item--has-dropdown .dropdown {
      display: none;
    }

    .nav-item--has-dropdown.is-open .dropdown {
      display: block;
    }

    .nav-item--has-dropdown.is-open .nav-chevron {
      transform: rotate(180deg);
    }
  }
</style>

<script>
  // Mobile menu toggle
  const menuToggle = document.querySelector('.mobile-menu-toggle');
  const primaryNav = document.querySelector('.primary-nav');

  menuToggle?.addEventListener('click', () => {
    const isOpen = primaryNav?.classList.toggle('is-open');
    menuToggle.setAttribute('aria-expanded', String(isOpen));
  });

  // Mobile dropdown toggles (tap to open)
  // On desktop with no hover support, also tap to open
  const dropdownToggles = document.querySelectorAll('.nav-link--toggle');

  dropdownToggles.forEach(toggle => {
    toggle.addEventListener('click', () => {
      const item = toggle.closest('.nav-item--has-dropdown');
      const isOpen = item?.classList.toggle('is-open');
      toggle.setAttribute('aria-expanded', String(isOpen));
    });
  });

  // Close dropdowns when clicking outside
  document.addEventListener('click', (e) => {
    if (!(e.target as Element).closest('.nav-item--has-dropdown')) {
      document.querySelectorAll('.nav-item--has-dropdown.is-open').forEach(item => {
        item.classList.remove('is-open');
        item.querySelector('.nav-link--toggle')?.setAttribute('aria-expanded', 'false');
      });
    }
  });
</script>