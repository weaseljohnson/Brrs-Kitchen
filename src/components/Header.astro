---
const navItems = [
  { label: 'Recipes',        href: '/recipes'  },
  { label: 'Learn / How-To', href: '/learn'    },
  { label: 'Glossary',       href: '/glossary' },
  { label: 'About',          href: '/about'    },
];
---

<header class="site-header">
  <div class="header-inner">

    <!-- Logo -->
    <a href="/" class="site-logo" aria-label="Brr's Kitchen home">
      <img
        src="/images/logo/BK-Logo-Header.png"
        alt="Brr's Kitchen"
        class="site-logo__img"
        width="1536"
        height="577"
      />
    </a>

    <!-- Mobile search toggle (icon only, shown at ≤900px) -->
    <button class="mobile-search-toggle" aria-label="Search" aria-expanded="false">
      <svg width="18" height="18" viewBox="0 0 16 16" fill="none" aria-hidden="true">
        <circle cx="6.5" cy="6.5" r="5" stroke="currentColor" stroke-width="1.5"/>
        <line x1="10.5" y1="10.5" x2="14.5" y2="14.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
      </svg>
    </button>

    <!-- Mobile menu toggle -->
    <button class="mobile-menu-toggle" aria-label="Open menu" aria-expanded="false" aria-controls="primary-nav">
      <span class="hamburger-bar"></span>
      <span class="hamburger-bar"></span>
      <span class="hamburger-bar"></span>
    </button>

    <!-- Primary nav -->
    <nav class="primary-nav" id="primary-nav" aria-label="Primary navigation">
      <ul class="nav-list" role="list">
        {navItems.map(item => (
          <li class={`nav-item${item.dropdown ? ' nav-item--has-dropdown' : ''}`}>
            {item.dropdown ? (
              <button
                class="nav-link nav-link--toggle"
                aria-expanded="false"
                aria-haspopup="true"
              >
                {item.label}
                <svg class="nav-chevron" width="10" height="6" viewBox="0 0 10 6" fill="none" aria-hidden="true">
                  <path d="M1 1l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </button>
            ) : (
              <a class="nav-link" href={item.href}>{item.label}</a>
            )}

            {item.dropdown && (
              <div class="dropdown" role="region">
                <div class="dropdown-inner">
                  {item.dropdown.columns.map(col => (
                    <div class="dropdown-col">
                      <p class="dropdown-heading">{col.heading}</p>
                      <ul role="list">
                        {col.links.map(link => (
                          <li>
                            <a class="dropdown-link" href={link.href}>{link.label}</a>
                          </li>
                        ))}
                      </ul>
                    </div>
                  ))}
                </div>
              </div>
            )}
          </li>
        ))}
        <li class="nav-item nav-item--search-bar">
          <div class="search-bar" role="search">
            <svg class="search-bar__icon" width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <circle cx="6.5" cy="6.5" r="5" stroke="currentColor" stroke-width="1.5"/>
              <line x1="10.5" y1="10.5" x2="14.5" y2="14.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
            <label for="site-search" class="sr-only">Search recipes</label>
            <input
              type="search"
              id="site-search"
              class="search-bar__input"
              placeholder="Search"
              aria-label="Search recipes"
            />
            <ul
              class="search-dropdown"
              id="desktop-search-dropdown"
              role="listbox"
              aria-label="Search suggestions"
              hidden
            ></ul>
          </div>
        </li>
      </ul>

    </nav>

  </div>
  <!-- Mobile search bar — expands below the header row on mobile -->
  <div class="mobile-search-bar" id="mobile-search-bar" aria-hidden="true">
    <div class="mobile-search-bar__inner">
      <svg class="mobile-search-bar__icon" ...>...</svg>
      <label for="mobile-search-input" class="sr-only">Search recipes</label>
      <input
        type="search"
        id="mobile-search-input"
        class="mobile-search-bar__input"
        placeholder="Search recipes…"
        aria-label="Search recipes"
      />
    </div>
    <ul
      class="search-dropdown search-dropdown--mobile"
      id="mobile-search-dropdown"
      role="listbox"
      aria-label="Search suggestions"
      hidden
    ></ul>
  </div>
</header>

<style>
  /* ── HEADER SHELL ── */
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: var(--color-bg);
  }

  .header-inner {
    max-width: var(--max-width-content);
    margin-inline: auto;
    padding-inline: var(--space-6);
    padding-block: var(--space-3);
    height: 125px;
    display: flex;
    align-items: center;
    gap: var(--space-6);
    position: relative;
  }

  /* ── LOGO ── */
  .site-logo {
    flex-shrink: 0;
    display: block;
    line-height: 0;
  }

  .site-logo__img {
    height: 100px;
    width: auto;
    display: block;
  }

  /* ── NAV ── */
  .primary-nav {
    margin-left: auto;
  }

  .nav-list {
    display: flex;
    align-items: center;
    gap: var(--space-1);
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .nav-item {
    position: relative;
  }

  .nav-link {
    display: flex;
    align-items: center;
    gap: var(--space-1);
    padding: var(--space-2) var(--space-3);
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    font-weight: 400;
    color: var(--color-text);
    text-decoration: none;
    border-radius: var(--radius-sm);
    border: none;
    background: none;
    cursor: pointer;
    white-space: nowrap;
    transition: color var(--transition-fast), background var(--transition-fast);
  }

  .nav-link:hover {
    color: var(--color-accent-3);
    background: rgba(121, 59, 2, 0.06);
  }

  .nav-chevron {
    transition: transform var(--transition-fast);
    flex-shrink: 0;
  }

  /* ── DESKTOP PILL SEARCH BAR ── */
  .nav-item--search-bar {
    margin-left: var(--space-3);
  }

  .search-bar {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    background: rgba(118, 130, 95, 0.07);
    border: 1px solid rgba(118, 130, 95, 0.22);
    border-radius: 999px;
    padding: var(--space-1) var(--space-3);
    transition:
      border-color var(--transition-fast),
      background var(--transition-fast);
  }

  .search-bar:focus-within {
    border-color: var(--color-accent-1);
    background: rgba(118, 130, 95, 0.12);
  }

  .search-bar__icon {
    color: var(--color-text-muted);
    flex-shrink: 0;
  }

  .search-bar__input {
    border: none;
    background: none;
    outline: none;
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    color: var(--color-text);
    width: 90px;
    transition: width var(--transition-base);
  }

  .search-bar__input:focus {
    width: 150px;
  }

  .search-bar__input::placeholder {
    color: var(--color-text-muted);
  }

  /* Clears browser default search cancel button (webkit) */
  .search-bar__input::-webkit-search-cancel-button {
    display: none;
  }

  /* ── MOBILE SEARCH TOGGLE ── */
  .mobile-search-toggle {
    display: none; /* shown only inside mobile media query */
    align-items: center;
    justify-content: center;
    background: none;
    border: none;
    cursor: pointer;
    padding: var(--space-2);
    color: var(--color-text);
    margin-left: auto; /* pushes both icons to the far right */
  }

  /* ── MOBILE SEARCH BAR (below header row) ── */
  .mobile-search-bar {
    display: none;
    background: var(--color-bg);
    border-top: 1px solid rgba(118, 130, 95, 0.2);
    padding: var(--space-2) var(--space-4);
    width: 100%; /* Force constraint to viewport */
    box-sizing: border-box;
  }

  .mobile-search-bar__inner {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    background: rgba(118, 130, 95, 0.08);
    border: 1px solid rgba(118, 130, 95, 0.22);
    border-radius: 999px;
    padding: var(--space-1) var(--space-4); /* Slightly tightened padding */
    width: 100%;
    box-sizing: border-box;
  }

  .mobile-search-bar__icon {
    color: var(--color-text-muted);
    flex-shrink: 0;
  }

  .mobile-search-bar__input {
    flex: 1;
    min-width: 0;
    width: 100%; /* Prevents text from pushing off the right edge */
    height: 36px; /* Explicit normal height to stop vertical inflation */
    box-sizing: border-box;
    border: none;
    background: none;
    outline: none;
    font-family: var(--font-sans);
    font-size: 16px; /* Explicit 16px prevents iOS auto-zoom */
    color: var(--color-text);
    padding: 0;
    margin: 0;
    -webkit-appearance: none; /* Crucial: clears Safari's default thick search bar styling */
  }

  .mobile-search-bar__input::placeholder {
    color: var(--color-text-muted);
  }

  /* ── DROPDOWN ── */
  .dropdown {
    display: none;
    position: absolute;
    top: calc(100% + var(--space-2));
    left: 50%;
    transform: translateX(-50%);
    background: var(--color-bg);
    border: 1px solid rgba(118, 130, 95, 0.2);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-lg);
    z-index: 200;
    min-width: 480px;
  }

  .dropdown-inner {
    display: flex;
    gap: var(--space-8);
    padding: var(--space-6);
  }

  .dropdown-col {
    min-width: 120px;
  }

  .dropdown-heading {
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    font-weight: 200;
    font-style: italic;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: var(--space-3);
    max-width: none;
  }

  .dropdown-col ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .dropdown-link {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    color: var(--color-text);
    text-decoration: none;
    transition: color var(--transition-fast);
  }

  .dropdown-link:hover {
    color: var(--color-accent-2);
  }

  /* Desktop: show dropdown on hover */
  @media (hover: hover) {
    .nav-item--has-dropdown:hover .dropdown {
      display: block;
    }

    .nav-item--has-dropdown:hover .nav-chevron {
      transform: rotate(180deg);
    }
  }

  /* ── SEARCH OVERLAY ── */
  .search-overlay {
    display: none;
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: var(--color-bg);
    z-index: 300;
    align-items: center;
    padding-inline: var(--space-6);
  }

  .search-overlay.is-open {
    display: flex;
  }

  .search-overlay__inner {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    width: 100%;
    max-width: var(--max-width-content);
    margin-inline: auto;
  }

  .search-overlay__input {
    flex: 1;
    background: rgba(118, 130, 95, 0.08);
    border: 1px solid rgba(118, 130, 95, 0.3);
    border-radius: var(--radius-lg);
    padding: var(--space-3) var(--space-5);
    font-family: var(--font-sans);
    font-size: var(--text-base);
    color: var(--color-text);
    transition: border-color var(--transition-fast);
  }

  .search-overlay__input:focus {
    outline: none;
    border-color: var(--color-accent-1);
  }

  .search-overlay__input::placeholder {
    color: var(--color-text-muted);
  }

  .search-overlay__close {
    display: flex;
    align-items: center;
    justify-content: center;
    background: none;
    border: none;
    cursor: pointer;
    color: var(--color-text-muted);
    padding: var(--space-2);
    border-radius: var(--radius-sm);
    transition: color var(--transition-fast);
    flex-shrink: 0;
  }

  .search-overlay__close:hover {
    color: var(--color-text);
  }

  /* ── SEARCH DROPDOWN ── */
  .search-dropdown {
    position: absolute;
    top: calc(100% + var(--space-2));
    left: 0;
    right: 0;
    background: var(--color-bg);
    border: 1px solid rgba(118, 130, 95, 0.22);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-lg);
    list-style: none;
    padding: var(--space-2);
    margin: 0;
    z-index: 300;
    min-width: 280px;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .search-dropdown[hidden] { display: none; }

  /* EVERYTHING BELOW MUST BE :global() BECAUSE IT IS INJECTED BY JS */

  .search-dropdown :global(.search-dropdown__item a) {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: var(--space-4);
    padding: var(--space-3);
    border: 1px solid rgba(118, 130, 95, 0.15); /* The nice card border */
    border-radius: var(--radius-md);
    text-decoration: none;
    color: inherit;
    transition: background var(--transition-fast), border-color var(--transition-fast);
  }

  .search-dropdown :global(.search-dropdown__item a:hover) {
    background: rgba(118, 130, 95, 0.04);
    border-color: rgba(118, 130, 95, 0.3);
  }

  .search-dropdown :global(.search-dropdown__img),
  .search-dropdown :global(.search-dropdown__img-placeholder) {
    width: 60px;
    height: 60px;
    object-fit: cover;
    border-radius: var(--radius-sm);
    flex-shrink: 0; /* Prevents the image from squishing */
    background: rgba(118, 130, 95, 0.08);
  }

  .search-dropdown :global(.search-dropdown__text) {
    display: flex;
    flex-direction: column;
    flex: 1;
    min-width: 0;
  }

  .search-dropdown :global(.search-dropdown__category) {
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    font-weight: 200;
    font-style: italic;
    color: var(--color-accent-2);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: var(--space-1);
  }

  .search-dropdown :global(.search-dropdown__title) {
    font-family: var(--font-serif);
    font-size: var(--text-lg);
    font-weight: 700;
    color: var(--color-text);
    margin: 0;
    line-height: 1.2;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .search-dropdown :global(.search-dropdown__see-all) {
    display: block;
    text-align: center;
    padding: var(--space-2) var(--space-4);
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    color: var(--color-accent-2);
    border-top: 1px solid rgba(118, 130, 95, 0.12);
    margin-top: var(--space-2);
    text-decoration: none;
    transition: color var(--transition-fast);
  }

  .search-dropdown :global(.search-dropdown__see-all:hover) { 
    color: var(--color-accent-3); 
  }

  /* Mobile dropdown sits below the input row, full-width */
  .search-dropdown--mobile {
    position: static;
    border-radius: 0 0 var(--radius-md) var(--radius-md);
    border: 1px solid rgba(118, 130, 95, 0.22);
    border-top: none;
    box-shadow: none;
    min-width: 0;
    width: 100%;
    margin-top: var(--space-1);
  }

  /* The mobile search bar needs relative positioning for the desktop variant
    but the mobile variant is static, so no extra CSS needed there */
  .nav-item--search-bar {
    position: relative;
  }

  /* ── MOBILE TOGGLE ── */
  .mobile-menu-toggle {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: var(--space-2);
    margin-left: 0;
  }

  .hamburger-bar {
    display: block;
    width: 22px;
    height: 2px;
    background: var(--color-text);
    border-radius: 2px;
    transition: transform var(--transition-fast), opacity var(--transition-fast);
  }

  /* Hidden on desktop, shown only inside mobile nav */
  .mobile-search {
    display: none;
    padding-top: var(--space-4);
  }

  /* ── MOBILE LAYOUT ── */
  @media (max-width: 900px) {
    .header-inner {
      height: 90px;
    }

    .site-logo__img {
      height: 64px;
    }

    .mobile-menu-toggle {
      display: flex;
    }

    .primary-nav {
      display: none;
      position: fixed;
      inset: 72px 0 0 0;
      background: var(--color-bg);
      overflow-y: auto;
      padding: var(--space-6);
      border-top: 1px solid rgba(118, 130, 95, 0.2);
      margin-left: 0;
    }

    .primary-nav.is-open {
      display: block;
    }

    .nav-list {
      flex-direction: column;
      align-items: flex-start;
      gap: 0;
    }

    .nav-item {
      width: 100%;
      border-bottom: 1px solid rgba(118, 130, 95, 0.1);
    }

    .nav-link {
      width: 100%;
      justify-content: space-between;
      padding: var(--space-4) 0;
      font-size: var(--text-base);
    }

    .dropdown {
      position: static;
      transform: none;
      box-shadow: none;
      border: none;
      border-radius: 0;
      min-width: 0;
      width: 100%;
    }

    .dropdown-inner {
      flex-direction: column;
      gap: var(--space-6);
      padding: 0 0 var(--space-4) var(--space-4);
    }

    .nav-item--has-dropdown .dropdown {
      display: none;
    }

    .nav-item--has-dropdown.is-open .dropdown {
      display: block;
    }

    .nav-item--has-dropdown.is-open .nav-chevron {
      transform: rotate(180deg);
    }
    /* Hide desktop pill search bar on mobile */
    .nav-item--search-bar {
      display: none;
    }

    /* Show mobile search toggle icon */
    .mobile-search-toggle {
      display: flex;
    }

    /* Show mobile search bar when toggled open */
    .mobile-search-bar.is-open {
      display: block;
    }
  }
</style>

<script>
  // ── ELEMENT REFERENCES ──
  const menuToggle = document.querySelector('.mobile-menu-toggle');
  const primaryNav = document.querySelector('.primary-nav');
  const mobileSearchToggle = document.querySelector('.mobile-search-toggle');
  const mobileSearchBar = document.querySelector('#mobile-search-bar');
  const mobileSearchInput = document.querySelector('#mobile-search-input') as HTMLInputElement;

  // ── MOBILE MENU TOGGLE ──
  menuToggle?.addEventListener('click', () => {
    const isOpen = primaryNav?.classList.toggle('is-open');
    menuToggle.setAttribute('aria-expanded', String(isOpen));
    // Close mobile search bar if it was open
    mobileSearchBar?.classList.remove('is-open');
    mobileSearchBar?.setAttribute('aria-hidden', 'true');
    mobileSearchToggle?.setAttribute('aria-expanded', 'false');
  });

  // ── MOBILE DROPDOWN TOGGLES ──
  const dropdownToggles = document.querySelectorAll('.nav-link--toggle');

  dropdownToggles.forEach(toggle => {
    toggle.addEventListener('click', () => {
      const item = toggle.closest('.nav-item--has-dropdown');
      const isOpen = item?.classList.toggle('is-open');
      toggle.setAttribute('aria-expanded', String(isOpen));
    });
  });

  // ── CLOSE DROPDOWNS ON OUTSIDE CLICK ──
  document.addEventListener('click', (e) => {
    if (!(e.target as Element).closest('.nav-item--has-dropdown')) {
      document.querySelectorAll('.nav-item--has-dropdown.is-open').forEach(item => {
        item.classList.remove('is-open');
        item.querySelector('.nav-link--toggle')?.setAttribute('aria-expanded', 'false');
      });
    }
  });

  // ── MOBILE SEARCH TOGGLE ──
  mobileSearchToggle?.addEventListener('click', () => {
    const isOpen = mobileSearchBar?.classList.toggle('is-open');
    mobileSearchBar?.setAttribute('aria-hidden', String(!isOpen));
    mobileSearchToggle.setAttribute('aria-expanded', String(isOpen));

    if (isOpen) {
      // Close hamburger nav if it was open
      primaryNav?.classList.remove('is-open');
      menuToggle?.setAttribute('aria-expanded', 'false');
      // Auto-focus the search input
      setTimeout(() => mobileSearchInput?.focus(), 50);
    }
  });

  // ── CLOSE MOBILE SEARCH ON ESCAPE ──
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && mobileSearchBar?.classList.contains('is-open')) {
      mobileSearchBar.classList.remove('is-open');
      mobileSearchBar.setAttribute('aria-hidden', 'true');
      mobileSearchToggle?.setAttribute('aria-expanded', 'false');
    }
  });

  // ── SEARCH ──
  const desktopInput    = document.getElementById('site-search')            as HTMLInputElement;
  const mobileInput     = document.getElementById('mobile-search-input')    as HTMLInputElement;
  const desktopDropdown = document.getElementById('desktop-search-dropdown') as HTMLElement;
  const mobileDropdown  = document.getElementById('mobile-search-dropdown')  as HTMLElement;

  let pagefind: any = null;

  async function loadPagefind() {
    if (pagefind) return;
    try {
      // @ts-ignore — pagefind index is generated at build time, not resolvable by Vite
      pagefind = await import('/pagefind/pagefind.js');
      await pagefind.init();
    } catch {
      pagefind = null;
    }
  }

  function buildDropdownHTML(results: any[], query: string): string {
    const items = results.map(r => {
      const img      = r.meta?.image ?? '';
      const category = r.meta?.category ?? '';
      const imgEl    = img
        ? `<img src="${img}" alt="" class="search-dropdown__img" loading="lazy" />`
        : `<div class="search-dropdown__img-placeholder" aria-hidden="true"></div>`;
      return `
        <li class="search-dropdown__item">
          <a href="${r.url}">
            ${imgEl}
            <div class="search-dropdown__text">
              ${category ? `<span class="search-dropdown__category">${category}</span>` : ''}
              <h3 class="search-dropdown__title">${r.meta?.title ?? 'Untitled'}</h3>
            </div>
          </a>
        </li>
      `;
    }).join('');
    
    const seeAll = `<a href="/search?q=${encodeURIComponent(query)}" class="search-dropdown__see-all">See all results →</a>`;
    return items + seeAll;
  }

  async function runHeaderSearch(query: string, inputEl: HTMLInputElement, dropdownEl: HTMLElement) {
    if (!query.trim()) {
      dropdownEl.hidden = true;
      return;
    }

    await loadPagefind();
    if (!pagefind) return; // Fail silently in dev

    const search  = await pagefind.search(query);
    const top3    = await Promise.all(search.results.slice(0, 3).map((r: any) => r.data()));

    if (top3.length === 0) {
      dropdownEl.hidden = true;
      return;
    }

    dropdownEl.innerHTML = buildDropdownHTML(top3, query);
    dropdownEl.hidden    = false;
  }

  function closeDropdowns() {
    desktopDropdown.hidden = true;
    mobileDropdown.hidden  = true;
  }

  function navigateToSearch(query: string) {
    if (query.trim()) {
      window.location.href = `/search?q=${encodeURIComponent(query.trim())}`;
    }
  }

  // Desktop input
  let desktopTimer: ReturnType<typeof setTimeout>;
  desktopInput?.addEventListener('input', () => {
    clearTimeout(desktopTimer);
    desktopTimer = setTimeout(() => runHeaderSearch(desktopInput.value, desktopInput, desktopDropdown), 250);
  });
  desktopInput?.addEventListener('keydown', e => {
    if (e.key === 'Enter') { e.preventDefault(); navigateToSearch(desktopInput.value); }
    if (e.key === 'Escape') closeDropdowns();
  });

  // Mobile input
  let mobileTimer: ReturnType<typeof setTimeout>;
  mobileInput?.addEventListener('input', () => {
    clearTimeout(mobileTimer);
    mobileTimer = setTimeout(() => runHeaderSearch(mobileInput.value, mobileInput, mobileDropdown), 250);
  });
  mobileInput?.addEventListener('keydown', e => {
    if (e.key === 'Enter') { e.preventDefault(); navigateToSearch(mobileInput.value); }
    if (e.key === 'Escape') closeDropdowns();
  });

  // Close dropdowns on outside click
  document.addEventListener('click', e => {
    if (
      !(e.target as Element).closest('.nav-item--search-bar') &&
      !(e.target as Element).closest('.mobile-search-bar')
    ) {
      closeDropdowns();
    }
  });
</script>