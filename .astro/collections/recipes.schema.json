{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "title": {
      "type": "string"
    },
    "category": {
      "type": "string"
    },
    "draft": {
      "type": "boolean"
    },
    "archived": {
      "type": "boolean"
    },
    "prepTime": {
      "type": "string"
    },
    "cookTime": {
      "type": "string"
    },
    "yield": {
      "type": "string"
    },
    "intro": {
      "type": "string"
    },
    "pubDate": {
      "type": "string"
    },
    "image": {
      "type": "string"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "dietary": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "credit": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "url": {
          "type": "string",
          "format": "uri"
        }
      },
      "required": [
        "name",
        "url"
      ]
    },
    "ingredients": {
      "type": "array",
      "items": {
        "anyOf": [
          {
            "type": "object",
            "properties": {
              "groupName": {
                "type": "string"
              },
              "ingredients": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "count": {
                      "type": "string"
                    },
                    "item": {
                      "type": "string"
                    }
                  },
                  "required": [
                    "item"
                  ]
                }
              }
            },
            "required": [
              "groupName",
              "ingredients"
            ]
          },
          {
            "type": "object",
            "properties": {
              "count": {
                "type": "string"
              },
              "item": {
                "type": "string"
              }
            },
            "required": [
              "item"
            ]
          }
        ]
      }
    },
    "panVariants": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "label": {
            "type": "string"
          },
          "yield": {
            "type": "string"
          },
          "ingredients": {
            "type": "array",
            "items": {
              "anyOf": [
                {
                  "type": "object",
                  "properties": {
                    "groupName": {
                      "type": "string"
                    },
                    "ingredients": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "count": {
                            "type": "string"
                          },
                          "item": {
                            "type": "string"
                          }
                        },
                        "required": [
                          "item"
                        ]
                      }
                    }
                  },
                  "required": [
                    "groupName",
                    "ingredients"
                  ]
                },
                {
                  "type": "object",
                  "properties": {
                    "count": {
                      "type": "string"
                    },
                    "item": {
                      "type": "string"
                    }
                  },
                  "required": [
                    "item"
                  ]
                }
              ]
            }
          }
        },
        "required": [
          "id",
          "label",
          "yield",
          "ingredients"
        ]
      }
    },
    "directions": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string"
          },
          "body": {
            "type": "string"
          }
        },
        "required": [
          "title",
          "body"
        ]
      }
    },
    "hasNotes": {
      "type": "boolean"
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "title",
    "category"
  ]
}