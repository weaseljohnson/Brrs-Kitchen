{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "title": {
      "type": "string"
    },
    "category": {
      "type": "string"
    },
    "prepTime": {
      "type": "string"
    },
    "cookTime": {
      "type": "string"
    },
    "yield": {
      "type": "string"
    },
    "intro": {
      "type": "string"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "dietary": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "pubDate": {
      "type": "string"
    },
    "image": {
      "type": "string"
    },
    "credit": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "url": {
          "type": "string",
          "format": "uri"
        }
      },
      "required": [
        "name",
        "url"
      ]
    },
    "hasNotes": {
      "type": "boolean"
    },
    "panVariants": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "label": {
            "type": "string"
          },
          "yield": {
            "type": "string"
          },
          "ingredients": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "count": {
                  "type": "string"
                },
                "item": {
                  "type": "string"
                }
              },
              "required": [
                "item"
              ]
            }
          }
        },
        "required": [
          "id",
          "label",
          "yield",
          "ingredients"
        ]
      }
    },
    "directions": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string"
          },
          "body": {
            "type": "string"
          }
        },
        "required": [
          "title",
          "body"
        ]
      }
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "title",
    "category"
  ]
}